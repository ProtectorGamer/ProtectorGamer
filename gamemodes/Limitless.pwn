  }
  return 1;
}

public OnPlayerKeyStateChange(playerid, newkeys, oldkeys)
{
    if(PlayerInfo[playerid][pDied] != 0)
	{
		return 1;
	}
    if(newkeys & KEY_CROUCH)
    {
       if(IsPlayerInAnyVehicle(playerid))
       {
           if(PlayerInfo[playerid][pMember] == LSS || PlayerInfo[playerid][pLeader] == LSS)
           {
		       if(PlayerToPoint(7.0, playerid, -74.8834,-358.9196,1.3986))
		       {//LSS gate 1
	               SetObjectRot(LSSgate1, 0.00, 0.00, 90.00);
	               SetTimer("LSSHQGate1Close", 10000, false);
			   }
		       else if(PlayerToPoint(7.0, playerid, -75.0505,-346.6007,1.4033))
		       {//LSS gate 2
	               SetObjectRot(LSSgate2, 0.00, 0.00, 90.00);
	               SetTimer("LSSHQGate2Close", 10000, false);
			   }
           }
           if(PlayerInfo[playerid][pMember] == FBI || PlayerInfo[playerid][pLeader] == FBI)
           {
               if(PlayerToPoint(7.0, playerid, 1644.0824,-1714.9872,15.6094))
	           {
	               MoveObject(FBIgate1, 1643.53, -1715.71, 09.05,2);
	               SetTimer("FBIHQGateClose", 10000, false);
			   }
           }
           if(PlayerInfo[playerid][pMember] == Police || PlayerInfo[playerid][pLeader] == Police)
           {
               if(PlayerToPoint(9.0, playerid, 1588.8958,-1637.6403,13.4407))
               {
			       MoveObject(LSPDGate1,1589.02,-1638.18, 7.18,2);
	               SetTimer("LSPD1GateClose", 10000, false);
			   }
			   if(PlayerToPoint(9.0, playerid, 1545.0781,-1627.5220,13.3828))
               {
                   SetObjectRot(LSPDGate2, 0.00, 0.00, 90.00);
	               SetTimer("LSPD2GateClose", 10000, false);
			   }
		   }
	   }
    }
    if(newkeys & KEY_ACTION)
    {
	    if (IsPlayerInAnyVehicle(playerid) && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
	    {
	        if (VehicleLightsOn[GetPlayerVehicleID(playerid)] == false)
	        {
                GetVehicleDamageStatus(GetPlayerVehicleID(playerid), panels, doors, lightz, tires);
	        	UpdateVehicleDamageStatus(GetPlayerVehicleID(playerid), panels, doors, encode_lights(0, 0, 0, 0), tires);
                VehicleLightsOn[GetPlayerVehicleID(playerid)] = true;
	        }
	        else
	        {
	    		GetVehicleDamageStatus(GetPlayerVehicleID(playerid), panels, doors, lightz, tires);
	        	UpdateVehicleDamageStatus(GetPlayerVehicleID(playerid), panels, doors, encode_lights(1, 1, 1, 1), tires);
	    		VehicleLightsOn[GetPlayerVehicleID(playerid)] = false;
			}
		}
    }
    if(newkeys & KEY_LEFT)
    {
       if(SelectChar[playerid] == 255)
       {
           if(PlayerInfo[playerid][pSex] == 1)
           {
		        if(SelectCharPlace[playerid] == 148) { SetPlayerSkin(playerid, CivMalePeds[147][0]); SelectCharPlace[playerid] = 147; PlayerInfo[playerid][pModel] = CivMalePeds[147][0]; }
	            else if(SelectCharPlace[playerid] == 147) { SetPlayerSkin(playerid, CivMalePeds[146][0]); SelectCharPlace[playerid] = 146; PlayerInfo[playerid][pModel] = CivMalePeds[146][0]; }
	            else if(SelectCharPlace[playerid] == 146) { SetPlayerSkin(playerid, CivMalePeds[145][0]); SelectCharPlace[playerid] = 145; PlayerInfo[playerid][pModel] = CivMalePeds[145][0]; }
		        else if(SelectCharPlace[playerid] == 145) { SetPlayerSkin(playerid, CivMalePeds[144][0]); SelectCharPlace[playerid] = 144; PlayerInfo[playerid][pModel] = CivMalePeds[144][0]; }
		        else if(SelectCharPlace[playerid] == 144) { SetPlayerSkin(playerid, CivMalePeds[143][0]); SelectCharPlace[playerid] = 143; PlayerInfo[playerid][pModel] = CivMalePeds[143][0]; }
		        else if(SelectCharPlace[playerid] == 143) { SetPlayerSkin(playerid, CivMalePeds[142][0]); SelectCharPlace[playerid] = 142; PlayerInfo[playerid][pModel] = CivMalePeds[142][0]; }
		        else if(SelectCharPlace[playerid] == 142) { SetPlayerSkin(playerid, CivMalePeds[141][0]); SelectCharPlace[playerid] = 141; PlayerInfo[playerid][pModel] = CivMalePeds[141][0]; }
		        else if(SelectCharPlace[playerid] == 141) { SetPlayerSkin(playerid, CivMalePeds[140][0]); SelectCharPlace[playerid] = 140; PlayerInfo[playerid][pModel] = CivMalePeds[140][0]; }
		        else if(SelectCharPlace[playerid] == 140) { SetPlayerSkin(playerid, CivMalePeds[139][0]); SelectCharPlace[playerid] = 139; PlayerInfo[playerid][pModel] = CivMalePeds[139][0]; }
		        else if(SelectCharPlace[playerid] == 139) { SetPlayerSkin(playerid, CivMalePeds[138][0]); SelectCharPlace[playerid] = 138; PlayerInfo[playerid][pModel] = CivMalePeds[138][0]; }
		        else if(SelectCharPlace[playerid] == 138) { SetPlayerSkin(playerid, CivMalePeds[137][0]); SelectCharPlace[playerid] = 137; PlayerInfo[playerid][pModel] = CivMalePeds[137][0]; }
