	                        if (strmatch(VehicleSystem[GetCreatorID(h)][owner],Spielername(playerid)))
	                        {
                                if(VehicleSystem[GetCreatorID(h)][Opened] == 0)
                                {
                                    VehicleSystem[GetCreatorID(h)][Opened] = 1;
				                    GetPlayerName(playerid, sendername, sizeof(sendername));
                                    SendClientMessage(playerid, COLOR_GREEN, "You have opened your vehicle for modification");
