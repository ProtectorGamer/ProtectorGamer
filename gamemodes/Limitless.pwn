	if(strcmp(cmd, "/checkprods", true) == 0)
	{
	    if(IsPlayerConnected(playerid))
        {
            if(PlayerInfo[playerid][pMember] != LSS)
		    {
				return 0;
		    }
            if(PlayerToPoint(5.0,playerid,-116.7558,-319.5848,1.4219))
            {
                format(string, sizeof(string), "LSS Company Products: [%d] Box Of Products", djInt("LG/Factions/LSS/LSS.json","Products/on"));
                SendClientMessage(playerid, COLOR_GREY, string);
			}
		}
	}
	if(strcmp(cmd, "/pickprod", true) == 0)
	{
	    if(IsPlayerConnected(playerid))
        {
            if(PlayerInfo[playerid][pMember] != LSS)
		    {
				return 0;
		    }
            if(PlayerToPoint(5.0,playerid,102.9611,-293.4775,1.5781))
            {
                if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT)
                {
                    if(PickProds[playerid] == 0)
				    {
                        new Float:vX,Float:vY,Float:vZ;
		                GetPlayerPos(playerid,vX,vY,vZ);
		                Object[playerid] = CreateObject(1271,vX,vY,vZ,0,0,0);
	                    AttachObjectToPlayer(Object[playerid], playerid,0,0.7,0.6,0,0,0);
		                LoopingAnim(playerid,"CARRY","crry_prtial",4.1,0,1,1,1,1);
		                djSetInt("LG/Factions/LSS/LSS.json","Products/on",djInt("LG/Factions/LSS/LSS.json","Products/on")-10);
                        PickProds[playerid] = 10;
                        SendClientMessage(playerid, COLOR_LIGHTRED, "You have pickedup a box of Products you can put it back '/dropprod'");
                        return 1;
