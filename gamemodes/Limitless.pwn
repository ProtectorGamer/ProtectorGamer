	if(strcmp(cmd, "/bank", true) == 0)
	{
	    if(Logged[playerid] == 1)
	    {
            if(!PlayerToPoint(3.0,playerid,2308.8220,-13.7179,26.7422))
            {
				return 1;
			}
            new x_nr[64];
	        x_nr = strtok(cmdtext, idx);
	        if(!strlen(x_nr))
	        {
                SendClientMessage(playerid, COLOR_GREY, "Function: {FFFFFF}/(/bank)[Action]");
     	        SendClientMessage(playerid, COLOR_BROWN, "Value: create - login - stats - transfer");
             	SendClientMessage(playerid, COLOR_BROWN, "If you want to withdraw or deposit use (/withdraw [$] to withdraw) and (/deposit [$] for depositing)");
                return 1;
	        }
	        if(Banksave == 1)
	        {
				return 0;
			}
	        if(strcmp(x_nr,"create",true) == 0)
	        {
                AddingBank[playerid] = 1;
                GetPlayerName(playerid, sendername, sizeof(sendername));
                format(string, sizeof(string), "|| Welcome to the State Bank, %s!",sendername);
                SendClientMessage(playerid, COLOR_LIGHTRED, string);
	            SendClientMessage(playerid, COLOR_WHITE2, "Please type the security code you want for your new account bank");
                SendClientMessage(playerid,COLOR_BROWN,"Details: The security code is a 6 numbers code");
                SendClientMessage(playerid,COLOR_RED,"Note: {FFFFFF}You can use /bank logout to cancel anytime");
	            PlayerPlaySound(playerid, 1056, 0.0, 0.0, 0.0);
	            return 1;
			}
			if(strcmp(x_nr,"login",true) == 0)
	        {
                GetPlayerName(playerid, sendername, sizeof(sendername));
                new logstring[200];
                format(logstring,sizeof(logstring),"Welcome %s, please write the bank account username",sendername);
                ShowPlayerDialog(playerid,40,DIALOG_STYLE_INPUT,"Bank Login System ...",logstring,"Login","Cancel");
	            PlayerPlaySound(playerid, 1056, 0.0, 0.0, 0.0);
	            AddingBank[playerid] = 2;
	            return 1;
			}
			if(strcmp(x_nr,"transfer",true) == 0)
	        {
                if(BankLogin[playerid] != 0)
                {
                    GetPlayerName(playerid, sendername, sizeof(sendername));
                    new logstring[200];
                    format(logstring,sizeof(logstring),"Welcome %s, please write the bank account username",sendername);
                    ShowPlayerDialog(playerid,41,DIALOG_STYLE_INPUT,"Bank Money Transfer ...",logstring,"Find","Cancel");
	                PlayerPlaySound(playerid, 1056, 0.0, 0.0, 0.0);
	                AddingBank[playerid] = 4;
	                return 1;
				}
			}
			if(strcmp(x_nr,"info",true) == 0)
	        {
				if(PlayerInfo[playerid][pBankPass] == 0)
				{
                    SendClientMessage(playerid,COLOR_LIGHTRED,"Note: {FFFFFF}You dont have an account please go to the bank and create one");
					return 1;
				}
                format(string, sizeof(string), "||- This is your bank account information -||");
                SendClientMessage(playerid, COLOR_GREY, string);
                format(string, sizeof(string), "Number: %s",PlayerInfo[playerid][pBankUser]);
                SendClientMessage(playerid, COLOR_WHITE2, string);
                format(string, sizeof(string), "Password: %d",PlayerInfo[playerid][pBankPass]);
                SendClientMessage(playerid, COLOR_WHITE2, string);
                PlayerPlaySound(playerid, 1056, 0.0, 0.0, 0.0);
                return 1;
			}
			if(strcmp(x_nr,"stats",true) == 0)
	        {
	            if (PlayerToPoint(5.0, playerid,2308.7505,-13.2901,26.7422))
	            {
		            if(BankLogin[playerid] != 0)
                    {
                        format(string, sizeof(string), "Account [%s]",BankInfo[playerid][Username]);
                        SendClientMessage(playerid,COLOR_LIGHTRED,string);
                        format(string, sizeof(string), "Money: $%d",dini_Int(BankInfo[playerid][Filename],"Cash"));
                        SendClientMessage(playerid,COLOR_WHITE2,string);
                        format(string, sizeof(string), "Saving: $%d",dini_Int(BankInfo[playerid][Filename],"Saving"));
                        SendClientMessage(playerid,COLOR_WHITE2,string);
                        format(string, sizeof(string), "LastDeposit: %s",dini_Get(BankInfo[playerid][Filename],"LastDeposit"));
                        SendClientMessage(playerid,COLOR_WHITE2,string);
                        format(string, sizeof(string), "LastWithdraw: %s",dini_Get(BankInfo[playerid][Filename],"LastWithdraw"));
                        SendClientMessage(playerid,COLOR_WHITE2,string);
                        format(string, sizeof(string), "LastTransfer: %s",dini_Get(BankInfo[playerid][Filename],"LastTransfer"));
                        SendClientMessage(playerid,COLOR_WHITE2,string);
                        PlayerPlaySound(playerid, 1056, 0.0, 0.0, 0.0);
                        return 1;
					}
					else { SendClientMessage(playerid,COLOR_RED,"You have no access to the bank please login to your bank account (/bank info)"); return 1; }
				}
				else { SendClientMessage(playerid,COLOR_RED,"You are not in a bank"); return 1; }
			}
			if(strcmp(x_nr,"logout",true) == 0)
	        {
                SendClientMessage(playerid, COLOR_RED, "Details: You have logged out from the bank");
