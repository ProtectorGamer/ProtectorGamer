        PlayerInfo[playerid][pGuns4] = 0;
    }
    if(PlayerInfo[playerid][pBullets5] == 0)
    {
        new text[64];
        text = "Empty";
        PlayerInfo[playerid][pGuns5Name] = text;
        PlayerInfo[playerid][pGuns5] = 0;
    }
    AmmoUpdate(playerid);
	if(Logged[playerid])
	{
			new string3[64];
			new playername3[MAX_PLAYER_NAME];
			GetPlayerName(playerid, playername3, sizeof(playername3));
