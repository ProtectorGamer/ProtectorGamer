			                SendClientMessage(playerid, COLOR_WHITE2, "You picked up your Ordered Package.");
			            }
			            case 4:
			            {
			                Otman_ResetPlayerWeapons(playerid);
                            PlayerInfo[playerid][pHandsGun1] = 4; PlayerInfo[playerid][pHandsBullets1] = 1;
							PlayerInfo[playerid][pHandsGun2] = 24; PlayerInfo[playerid][pHandsBullets2] = 200;
							PlayerInfo[playerid][pHandsGun3] = 31; PlayerInfo[playerid][pHandsBullets3] = 350;
							PlayerInfo[playerid][pHandsGun4] = 34; PlayerInfo[playerid][pHandsBullets4] = 50;
							PlayerWeap(playerid);
			                Otman_TakePlayerMoney(playerid,500);
			                SendClientMessage(playerid, COLOR_WHITE2, "You picked up your Ordered Package.");
