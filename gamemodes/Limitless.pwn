								{
                                    VehicleSystem[GetCreatorID(h)][Trunk] = 0;
				                    GetPlayerName(playerid, sendername, sizeof(sendername));
                                    format(string, sizeof(string), "%s open's the vehicle trunk", sendername);
		                            ProxDetector(5.0, playerid, string, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
				                    return 1;
								}
								else if(VehicleSystem[GetCreatorID(h)][Trunk] == 0)
