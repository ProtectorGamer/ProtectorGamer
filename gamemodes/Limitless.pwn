			if(IsPlayerConnected(giveplayerid))
			{
				if(giveplayerid != INVALID_PLAYER_ID)
				{
				    if (ProxDetectorS(8.0, playerid, giveplayerid))
					{
					    if(giveplayerid == playerid) { SendClientMessage(playerid, COLOR_GREY, "You must use /mylicenses to view your own licenses."); return 1; }
					    GetPlayerName(giveplayerid, giveplayer, sizeof(giveplayer));
						GetPlayerName(playerid, sendername, sizeof(sendername));
					    new text1[20];
				        new text2[20];
				        new text4[20];
				        new text5[20];
						if(PlayerInfo[playerid][pCarLic] == 1) { text1 = "Passed"; } else { text1 = "Not Passed"; }
                        if(PlayerInfo[playerid][pFlyLic] == 1) { text4 = "Passed"; } else { text4 = "Not Passed"; }
						if(PlayerInfo[playerid][pBoatLic] == 1) { text2 = "Passed"; } else { text2 = "Not Passed"; }
				        if(PlayerInfo[playerid][pGunLic] == 1) { text5 = "Passed"; } else { text5 = "Not Passed"; }
				        format(string, sizeof(string), "-----------[Licensing Papers of %s]------------", sendername);
				        SendClientMessage(giveplayerid, COLOR_LIGHTRED, string);
				        format(string, sizeof(string), "Drivers License: %s", text1);
						SendClientMessage(giveplayerid, COLOR_WHITE2, string);
						format(string, sizeof(string), "Flying License: %s", text4);
						SendClientMessage(giveplayerid, COLOR_WHITE2, string);
						format(string, sizeof(string), "Sailing License: %s", text2);
						SendClientMessage(giveplayerid, COLOR_WHITE2, string);
						format(string, sizeof(string), "Weapon License: %s", text5);
						SendClientMessage(giveplayerid, COLOR_WHITE2, string);
						format(string, sizeof(string), "%s withdraws some papers, showing them to you.", sendername);
						SendClientMessage(giveplayerid, COLOR_YELLOW, string);
						format(string, sizeof(string), "As you withdraw your papers, you show them to %s.", giveplayer);
						SendClientMessage(playerid, COLOR_LIGHTRED, string);
					}
					else
					{
					    SendClientMessage(playerid, COLOR_GREY, "That player is not near you");
					    return 1;
					}
				}
			}
	        else
	        {
	            SendClientMessage(playerid, COLOR_GREY, "That player is Offline");
	            return 1;
	        }
		}
	    return 1;
 	}
