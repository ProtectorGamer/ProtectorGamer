    if (strcmp(cmdtext, "/lock", true) == 0)
    {
        if(IsPlayerInAnyVehicle(playerid))
        {
            if(GetCreatorID(vehicleid) != 0)
            {
		        SendClientMessage(playerid,COLOR_RED,"You can not lock an ownable vehicle with this command !");
		        return 1;
		    }
            new Stat5 = GetPlayerState(playerid);
            if(Stat5!=PLAYER_STATE_DRIVER)
            {
                SendClientMessage(playerid,COLOR_GREY,"You are not a driver");
                return 1;
            }
            for(new i=0;i<GetMaxPlayers();i++)
            {
                if(i != playerid)
                {
                    SetVehicleParamsForPlayer(vehicleid,i, 0, 1);
                }
                GetPlayerName(playerid, sendername, sizeof(sendername));
                SendClientMessage(playerid, 0x6A7995FF, "[LOCK] Vehicle locked! (10 minuts)");
                new Float:pX, Float:pY, Float:pZ;
                GetPlayerPos(playerid,pX,pY,pZ);
                PlayerPlaySound(playerid,1056,pX,pY,pZ);
                lockedcar[playerid][GetPlayerVehicleID(playerid)] = 1;
                lockedveh[GetPlayerVehicleID(playerid)] = 1;
                unlockcartimer[playerid] = SetTimerEx("unlocktimercar",300000,false,"i",playerid,GetPlayerVehicleID(playerid));
			    return 1;
			}
		}
    }
    if (strcmp(cmdtext, "/unlock", true) == 0)
    {
        if(IsPlayerInAnyVehicle(playerid))
        {
            if(GetCreatorID(vehicleid) != 0)
            {
		        SendClientMessage(playerid,COLOR_RED,"You can not lock an ownable vehicle with this command !");
		        return 1;
		    }
            new Stat5=GetPlayerState(playerid);
            if(Stat5!=PLAYER_STATE_DRIVER)
            {
                SendClientMessage(playerid,COLOR_GREY,"You are not a driver");
                return 1;
            }
            if(lockedcar[playerid][GetPlayerVehicleID(playerid)] != 1)
            {
				return 1;
			}
            for(new i=0;i<GetMaxPlayers();i++)
            {
                if(i != playerid)
                {
                    SetVehicleParamsForPlayer(vehicleid,i, 0, 0);
                }
                GetPlayerName(playerid, sendername, sizeof(sendername));
                SendClientMessage(playerid, 0x6A7995FF, "[LOCK] Vehicle unlocked!");
                new Float:pX, Float:pY, Float:pZ;
                GetPlayerPos(playerid,pX,pY,pZ);
                PlayerPlaySound(playerid,1057,pX,pY,pZ);
                lockedcar[playerid][GetPlayerVehicleID(playerid)] = 0;
                lockedveh[GetPlayerVehicleID(playerid)] = 0;
                KillTimer(unlockcartimer[playerid]);
                return 1;
