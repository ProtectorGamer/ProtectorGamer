	        {
                if(DriverTest[playerid] == 100)
                {
	                SendClientMessage(playerid,COLOR_YELLOW,"||- The test have been started, please drive carefully");
	                SetPlayerCheckpoint(playerid, 1270.1693,-1844.1124,13.0986, 6);
	                TogglePlayerControllable(playerid, 1);
	                new Float:pX, Float:pY, Float:pZ;
                    GetPlayerPos(playerid,pX,pY,pZ);
				    PlayerPlaySound(playerid,1056,pX,pY,pZ);
				    SetTimerEx("DriverTestTimer", 1000, false, "i", playerid);
	                DriverTest[playerid] = 1;
	                return 1;
				}
			}
			if(GetPlayerVehicleID(playerid) == 48 || GetPlayerVehicleID(playerid) == 49)
	        {
				if(DriverTest[playerid] == 200)
                {
	                SendClientMessage(playerid,COLOR_Milito,"||- The test have been started, please drive carefully");
	                SetPlayerCheckpoint(playerid, 207.3625,-1943.9977,-0.5149, 6);
