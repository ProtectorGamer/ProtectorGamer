			if(!strlen(tmp))
			{
				SendClientMessage(playerid, COLOR_GRAD1, "Function: {FFFFFF}/contract [ID or Name/Part of name] [amount]");
				return 1;
			}
			moneys = strval(tmp);
			if(moneys < 1000 || moneys > 100000) { SendClientMessage(playerid, COLOR_GREY, "Contract money must be atleast $1000, and not more then $100000!"); return 1; }
			if (IsPlayerConnected(giveplayerid))
			{
			    if(giveplayerid != INVALID_PLAYER_ID)
			    {
				    if(PlayerInfo[giveplayerid][pMember] == Hitmen && PlayerInfo[playerid][pMember] == Hitmen)
				    {
				        return 1;
				    }
				    if(PlayerInfo[giveplayerid][pMember] == Police && moneys != 100000)
				    {
				        SendClientMessage(playerid, COLOR_GREY, "$100000 and higher can be placed as a contract on cops !");
				        return 1;
				    }
				    if(giveplayerid == playerid) { SendClientMessage(playerid, COLOR_GREY, "You want to Contract yourself?"); return 1; }
					GetPlayerName(giveplayerid, giveplayer, sizeof(giveplayer));
					GetPlayerName(playerid, sendername, sizeof(sendername));
					playermoney = Otman_GetPlayerMoney(playerid);
					if (moneys > 0 && playermoney >= moneys)
					{
						Otman_TakePlayerMoney(playerid, moneys);
						PlayerInfo[giveplayerid][pHeadValue]+=moneys;
						format(string, sizeof(string), "%s has placed a contract on %s, for $%d.",sendername, giveplayer, moneys);
						SendFamilyMessage(Hitmen, COLOR_YELLOW, string);
						format(string, sizeof(string), "You placed a contract on %s, for $%d.",giveplayer, moneys);
						SendClientMessage(playerid, COLOR_WHITE2, string);
						PlayerPlaySound(playerid, 1052, 0.0, 0.0, 0.0);
					}
					else
					{
						SendClientMessage(playerid, COLOR_GRAD1, "Invalid transaction amount.");
					}
				}
			}
		}
		return 1;
	}
	if(strcmp(cmd, "/find", true) == 0)
