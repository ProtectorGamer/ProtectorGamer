	    format(loader,sizeof(loader),"veh_mod16_%d",i);
	    VehicleSystem[i][mod16] = dini_Int("LG/Vehicles/PlayerVehicles/Cars.ini",loader);
	    format(loader,sizeof(loader),"veh_mod17_%d",i);
        VehicleSystem[i][mod17] = dini_Int("LG/Vehicles/PlayerVehicles/Cars.ini",loader);
        format(loader,sizeof(loader),"veh_paintjob_%d",i);
        VehicleSystem[i][paintjob] = dini_Int("LG/Vehicles/PlayerVehicles/Cars.ini",loader);
        Loadingcars = 0;
 	    if(VehicleSystem[i][model]!=0)
		{
			new car = CreateVehicle(VehicleSystem[i][model],VehicleSystem[i][carx],VehicleSystem[i][cary],VehicleSystem[i][carz],VehicleSystem[i][cara],VehicleSystem[i][Farbe1],VehicleSystem[i][Farbe2],600000);
			IDIS[car] = i;
			VehicleSystem[IDIS[car]][Trunk] = 1;
 	        Tunen(car);
 	    }
 	    if(CarLocate[playerid] == 0)
        {
            SetPlayerCheckpoint(playerid,VehicleSystem[i][carx],VehicleSystem[i][cary],VehicleSystem[i][carz], 5.0);
            SendClientMessage(playerid,COLOR_GREY,"Note: {FFFFFF}Your vehicle position has been located in the map");
            CarLocate[playerid] = 1;
		}
	}
	return 1;
}

