public OnVehiclePaintjob(playerid, vehicleid, paintjobid)
{
    if(GetCreatorID(vehicleid)!=0)
    {
        VehicleSystem[GetCreatorID(vehicleid)][paintjob] = paintjobid;
        return 1;
	}
	return 1;
}

public OnVehicleRespray (playerid, vehicleid, color1, color2)
{
    if(GetCreatorID(vehicleid)!=0)
    {
        VehicleSystem[GetCreatorID(vehicleid)][Farbe1] = color1;
        VehicleSystem[GetCreatorID(vehicleid)][Farbe2] = color2;
        return 1;
	}
	return 1;
}

public LoadData()
{
    if(!dini_Exists("LG/Accounts/Database/Data.cfg"))
	{
	    dini_Create("LG/Accounts/Database/Data.cfg");
	}
	new dataloader[20];
	for(new i = 0;i<100;i++)
	{
        format(dataloader,sizeof(dataloader),"Player_ID_%d",i);
	    DataInfo[i][PlayerID] = dini_Int("LG/Accounts/Database/Data.cfg",dataloader);
 	    format(dataloader,sizeof(dataloader),"Player_Name_%d",i);
 	    strmid(DataInfo[i][PlayerName],dini_Get("LG/Accounts/Database/Data.cfg",dataloader),0,20,20);
 	    format(dataloader,sizeof(dataloader),"Player_Age_%d",i);
	    strmid(DataInfo[i][PlayerAge],dini_Get("LG/Accounts/Database/Data.cfg",dataloader),0,20,20);
        format(dataloader,sizeof(dataloader),"Player_JailTimes_%d",i);
 	    strmid(DataInfo[i][JailTimes],dini_Get("LG/Accounts/Database/Data.cfg",dataloader),0,20,20);
	    format(dataloader,sizeof(dataloader),"Player_DrivingWarnings_%d",i);
 	    strmid(DataInfo[i][DrivingWarnings],dini_Get("LG/Accounts/Database/Data.cfg",dataloader),0,20,20);
 	    format(dataloader,sizeof(dataloader),"Player_IllegalItems_%d",i);
 	    strmid(DataInfo[i][IllegalItems],dini_Get("LG/Accounts/Database/Data.cfg",dataloader),0,20,20);
 	    if(DataInfo[i][PlayerID]!=0)
		{
 	        createddata++;
		}
    }
    return 1;
}

public SaveData()
{
	new count;
	new saver[20];
	fremove("LG/Accounts/Database/Data.cfg");
	dini_Create("LG/Accounts/Database/Data.cfg");
	for(new i = 0;i<100;i++)
	{
		if(DataInfo[i][PlayerID] != 0)
        {
            count++;
	        format(saver,sizeof(saver),"Player_ID_%d",count);
            dini_IntSet("LG/Accounts/Database/Data.cfg",saver,DataInfo[i][PlayerID]);
            format(saver,sizeof(saver),"Player_Name_%d",count);
            dini_Set("LG/Accounts/Database/Data.cfg",saver,DataInfo[i][PlayerName]);
            format(saver,sizeof(saver),"Player_Age_%d",count);
            dini_Set("LG/Accounts/Database/Data.cfg",saver,DataInfo[i][PlayerAge]);
            format(saver,sizeof(saver),"Player_JailTimes_%d",count);
            dini_Set("LG/Accounts/Database/Data.cfg",saver,DataInfo[i][JailTimes]);
            format(saver,sizeof(saver),"Player_DrivingWarnings_%d",count);
            dini_Set("LG/Accounts/Database/Data.cfg",saver,DataInfo[i][DrivingWarnings]);
            format(saver,sizeof(saver),"Player_IllegalItems_%d",count);
            dini_Set("LG/Accounts/Database/Data.cfg",saver,DataInfo[i][IllegalItems]);
		}
	}
	return 1;
}

public OnDialogResponse(playerid, dialogid, response, listitem, inputtext[])
{
	new sendername[MAX_PLAYER_NAME];
	new string[128];
	if(response)
	{
		if(dialogid == 12346 || dialogid == 12347)
		{
		    if(strlen(inputtext))
		    {
				new tmppass[64];
				strmid(tmppass, inputtext, 0, strlen(inputtext), 255);
				Encrypt(tmppass);
				OnPlayerLogin(playerid,tmppass);
				return 0;
			}
			else
			{
				new loginstring[128];
				new loginname[64];
				GetPlayerName(playerid,loginname,sizeof(loginname));
				format(loginstring,sizeof(loginstring),"WRONG PASSWORD\nPlease Enter The Correct Password",loginname);
				ShowPlayerDialog(playerid,12347,DIALOG_STYLE_PASSWORD,"Wrong Password",loginstring,"Login","Cancel");
				LogTries[playerid] += 1;
				if(LogTries[playerid] == 4) { Kick(playerid); return 0; }
			}
		}
		if(dialogid == 40)
		{
		    if(strlen(inputtext))
		    {
				new file[100];
	            format(file, sizeof(file), "LG/Finance/BankAccounts/%s.bank", inputtext);
	            if(dini_Exists(file))
	            {
				    format(string, sizeof(string), "Account Founded [%s] ...",inputtext);
	                SendClientMessage(playerid,COLOR_LIGHTRED,string);
	                SendClientMessage(playerid,COLOR_WHITE2,"Now please write the 6 numbers security code");
	                strmid(BankInfo[playerid][Filename],file,0,100,100);
	                strmid(BankInfo[playerid][Username],inputtext,0,64,64);
	                AddingBank[playerid] = 3;
	                return 0;
				}
				else
				{
				    SendClientMessage(playerid,COLOR_LIGHTRED,"Details: There is no such username !");
				}
			}
		}
		if(dialogid == 41)
		{
		    if(strlen(inputtext))
		    {
				new file[100];
	            format(file, sizeof(file), "LG/Finance/BankAccounts/%s.bank", inputtext);
	            if(dini_Exists(file))
	            {
				    format(string, sizeof(string), "Account Founded [%s] ...",inputtext);
	                SendClientMessage(playerid,COLOR_LIGHTRED,string);
	                SendClientMessage(playerid,COLOR_WHITE2,"Now please type how much money you want to transfer");
	                strmid(BankInfo[playerid][Filename2],file,0,100,100);
	                strmid(BankInfo[playerid][Username2],inputtext,0,64,64);
	                AddingBank[playerid] = 5;
	                BankTransfer[playerid] = 1;
	                return 0;
				}
				else
				{
				    SendClientMessage(playerid,COLOR_LIGHTRED,"Details: There is no such username !");
				}
			}
		}
		if(dialogid == 20)
		{
		    if(strlen(inputtext))
		    {
				new file[100];
	            format(file, sizeof(file), "LG/Accounts/BannedPlayers/%s.ban", inputtext);
	            if(dini_Exists(file))
	            {
				    dini_Remove(file);
				    SendClientMessage(playerid,COLOR_LIGHTRED,"Details: Succsufully unbanned");
				    return 0;
				}
				else
				{
				    SendClientMessage(playerid,COLOR_LIGHTRED,"Name not found");
				}
	            return 0;
			}
		}
		if(dialogid == 21)
		{
		    if(strlen(inputtext))
		    {
				new file[20];
	            format(file, sizeof(file), "LG/Accounts/BannedPlayers/%s.ban", inputtext);
	            if(dini_Exists(file))
	            {
                    format(string, sizeof(string), "Player: %s",inputtext);
	                SendClientMessage(playerid,COLOR_LIGHTRED,string);
                    format(string, sizeof(string), "BannedBy: %s",dini_Int(file,"Banned-By"));
	                SendClientMessage(playerid,COLOR_WHITE2,string);
	                format(string, sizeof(string), "Reason: %s",dini_Int(file,"Reason"));
	                SendClientMessage(playerid,COLOR_WHITE2,string);
	                return 0;
				}
				else
				{
				    SendClientMessage(playerid,COLOR_LIGHTRED,"Name not found");
				}
			}
		}
		if(dialogid == 10000)
		{
		    if(strlen(inputtext))
		    {
				createddata++;
	            strmid(DataInfo[createddata][PlayerName],inputtext,0,20,20);
	            DataInfo[createddata][PlayerID] = createddata;
	            format(string, sizeof(string), "||- %s Suspect name has been added -||", inputtext);
	            SendClientMessage(playerid,COLOR_Milito,string);
	            PlayerPlaySound(playerid, 1056, 0.0, 0.0, 0.0);
	            SendClientMessage(playerid,GREEN,"||- Please type the suspect age now");
	            DataNum[playerid] = createddata;
	            AddingData[playerid] = 2;
	            return 0;
			}
		}
		if(dialogid == 10001)
		{
		    if(strlen(inputtext))
		    {
		        for(new i = 0;i<100;i++)
	            {
		            if(DataInfo[i][PlayerID] != 0)
                    {
		                if(strmatch(DataInfo[i][PlayerName],inputtext))
                        {
							// Use a command to Clear the chatbox right here !!
	                        SendClientMessage(playerid,GREEN,":: Search Results ::-------------");
	                        format(string, sizeof(string), "Name: %s",DataInfo[i][PlayerName]);
	                        SendClientMessage(playerid,COLOR_WHITE2,string);
	                        format(string, sizeof(string), "Age: %s",DataInfo[i][PlayerAge]);
	                        SendClientMessage(playerid,COLOR_WHITE2,string);
	                        format(string, sizeof(string), "Jailtimes: %s",DataInfo[i][JailTimes]);
	                        SendClientMessage(playerid,COLOR_WHITE2,string);
	                        format(string, sizeof(string), "Driving-Warnings: %s",DataInfo[i][DrivingWarnings]);
	                        SendClientMessage(playerid,COLOR_WHITE2,string);
	                        format(string, sizeof(string), "Illegal-items: %s",DataInfo[i][IllegalItems]);
	                        SendClientMessage(playerid,COLOR_WHITE2,string);
	                        SendClientMessage(playerid,GREEN,"---------------------------------");
	                        PlayerPlaySound(playerid, 1056, 0.0, 0.0, 0.0);
	                        AddingData[playerid] = 0;
	                        return 0;
						}
					}
				}
			}
		}
		if(dialogid == 10002)
		{
		    if(strlen(inputtext))
		    {
		        for(new i = 0;i<100;i++)
	            {
		            if(DataInfo[i][PlayerID] != 0)
                    {
		                if(strmatch(DataInfo[i][PlayerName],inputtext))
                        {
                            // Use a command to Clear the chatbox right here !!
                            format(string, sizeof(string), ":: %s founded :---------",DataInfo[i][PlayerName]);
	                        SendClientMessage(playerid,GREEN,string);
	                        format(string, sizeof(string), "Age: %s",DataInfo[i][PlayerAge]);
	                        SendClientMessage(playerid,COLOR_WHITE2,string);
	                        format(string, sizeof(string), "Jail-Times: %s",DataInfo[i][JailTimes]);
	                        SendClientMessage(playerid,COLOR_WHITE2,string);
	                        format(string, sizeof(string), "Driving-Warnings: %s",DataInfo[i][DrivingWarnings]);
	                        SendClientMessage(playerid,COLOR_WHITE2,string);
	                        format(string, sizeof(string), "Illegal-Items: %s",DataInfo[i][IllegalItems]);
	                        PlayerPlaySound(playerid, 1056, 0.0, 0.0, 0.0);
	                        SendClientMessage(playerid,COLOR_LIGHTRED,"To edit(Type : Age - Jailtimes - DrivingWarnings - Illegalitems)");
	                        AddingData[playerid] = 8;
	                        DataNum[playerid] = DataInfo[i][PlayerID];
	                        return 0;
						}
					}
				}
			}
		}
		if(dialogid == 12345)
		{
		    if(strlen(inputtext))
		    {
				GetPlayerName(playerid, sendername, sizeof(sendername));
				format(string, sizeof(string), "LG/Accounts/%s.ini", sendername);
				new File: hFile = fopen(string, io_read);
				if (hFile)
				{
					SendClientMessage(playerid, COLOR_YELLOW, "The given username is already within our database. Please choose a new name.");
					fclose(hFile);
					return 1;
				}
				new tmppass[64];
				strmid(tmppass, inputtext, 0, strlen(inputtext), 255);
				Encrypt(tmppass);
				OnPlayerRegister(playerid,tmppass);
				return 0;
			 }
			 else
			 {
 				new regstring[128];
				new regname[64];
				GetPlayerName(playerid,regname,sizeof(regname));
				format(regstring,sizeof(regstring),"Welcome to Limitless Gaming, %s!\nThis account has not been found within our database.\nPlease type a password below to register:",regname);
				ShowPlayerDialog(playerid,12345,DIALOG_STYLE_PASSWORD,"Registration",regstring,"Register","Cancel");
				return 0;
			}
		}
		if(dialogid == 55)
		{
			if(listitem == 0)
			{
                new loginstring[128];
	            new loginname[64];
                Gender[playerid] = 1;
                GetPlayerName(playerid,loginname,sizeof(loginname));
				format(loginstring,sizeof(loginstring),"The account '%s' is now registered!\nYou may now login with your chosen password:",loginname);
				ShowPlayerDialog(playerid,12346,DIALOG_STYLE_PASSWORD,"Authentication",loginstring,"Login","Cancel");
				return 0;
                
			}
			if(listitem == 1)
			{
                new loginstring[128];
	            new loginname[64];
                Gender[playerid] = 2;
                GetPlayerName(playerid,loginname,sizeof(loginname));
				format(loginstring,sizeof(loginstring),"The account '%s' is now registered!\nYou may now login with your chosen password:",loginname);
				ShowPlayerDialog(playerid,12346,DIALOG_STYLE_PASSWORD,"Authentication",loginstring,"Login","Cancel");
				return 0;
			}
		}
		if(dialogid == 15)
