                    if(PlayerInfo[playerid][pPnumber] == 0)
			        {
				        SendClientMessage(playerid, COLOR_GRAD2, "Our Service Require a phone number");
				        return 1;
			        }
			        if ((advertise == 0))
			        {
				        SendClientMessage(playerid, COLOR_GRAD2, "Details: Please come back later ..");
				        return 1;
			        }
			        if(Otman_GetPlayerMoney(playerid) < ADInfo[h][adPrice])
	                {
	                    format(string, sizeof(string), "You Need $%d To Make an Advertisment",ADInfo[h][adPrice]);
	                    SendClientMessage(playerid, COLOR_GREY, string);
	                    return 1;
	                }
			        Otman_TakePlayerMoney(playerid,ADInfo[h][adPrice]);
			        ADInfo[h][adTill] += ADInfo[h][adPrice];
			        format(string, sizeof(string), "You Have Paied $%d For The Advertise", ADInfo[h][adPrice]);
			        SendClientMessage(playerid, COLOR_PINKY, string);
			        format(string, sizeof(string), "[Advertisement]: From %s [Phone: %d]",sendername,PlayerInfo[playerid][pPnumber]);
			        SendClientMessageToAll(0x24FF4AFF,string);
			        format(string, sizeof(string), "%s",result);
			        SendClientMessageToAll(0x24FF4AFF,string);
			        addtimer = SetTimer("AddsOn", 60000, false);
					advertise = 0;
					return 1;
                }
                else
                {
                    SendClientMessage(playerid, COLOR_GRAD2, "To make an advertisment you must request this service from an advertisment company");
                    return 1;
		        }
			}
	    }
        return 1;
    }
