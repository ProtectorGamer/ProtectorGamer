	        tmp = strtok(cmdtext, idx);
		    if(!strlen(tmp))
		    {
			    SendClientMessage(playerid, COLOR_GREY, "Correct: /giveweapon [Your slot] [PlayerID]");
			    return 1;
		    }
	        new slot = strval(tmp);
	        if(slot < 1 || slot > 5)
	        {
			    SendClientMessage(playerid, COLOR_WHITE2, "Max Player Packages are 5");
			    return 1;
		    }
            tmp = strtok(cmdtext, idx);
