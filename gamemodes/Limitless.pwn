	            if(PlayerToPoint(2.0, playerid, DealerInfo[h][dsEntrancex], DealerInfo[h][dsEntrancey], DealerInfo[h][dsEntrancez]) && DealerInfo[h][dsOwned] == 0)
			    {
                    if(Otman_GetPlayerMoney(playerid) > DealerInfo[h][dsPrice])
				    {
                        if(PlayerInfo[playerid][pDealership] < 3)
					    {
                            DealerInfo[h][dsOwned] = 1;
						    PlayerInfo[playerid][pDealership] += 1;
						    GetPlayerName(playerid, sendername, sizeof(sendername));
						    strmid(ClubInfo[h][clOwner], sendername, 0, strlen(sendername), 255);
						    Otman_TakePlayerMoney(playerid,DealerInfo[h][dsPrice]);
						    SendClientMessage(playerid, COLOR_LIGHTRED, "<< Congratulations You Have Bought A Dealership For More Information Type /bhelp >>");
						    UpdatePlayerInfo(playerid);
						    return 1;
						}
					}
				}
			}
		}
		return 1;
	}
