			{
				SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/Deposit [amount]");
				format(string, sizeof(string), "You Have $%d in your account.", BankInfo[playerid][Cash]);
				SendClientMessage(playerid, COLOR_GRAD3, string);
				return 1;
			}
			new cashdeposit = strval(tmp);
			if(!strlen(tmp))
			{
				SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/Deposit [amount]");
				format(string, sizeof(string), "You Have $%d in your account.", BankInfo[playerid][Cash]);
				SendClientMessage(playerid, COLOR_GRAD3, string);
				return 1;
			}
			if (cashdeposit > Otman_GetPlayerMoney(playerid) || cashdeposit < 0)
			{
				SendClientMessage(playerid, COLOR_GRAD2, "You dont have that much");
				return 1;
			}
			GetPlayerName(playerid, sendername, sizeof(sendername));
			Otman_TakePlayerMoney(playerid,cashdeposit);
			new curfunds = BankInfo[playerid][Cash];
			BankInfo[playerid][Cash] = cashdeposit+BankInfo[playerid][Cash];
			dini_IntSet(BankInfo[playerid][Filename],"Cash",BankInfo[playerid][Cash]);
			SendClientMessage(playerid, COLOR_YELLOW, "Bank Statement");
			format(string, sizeof(string), "Old Balance: $%d", curfunds);
			SendClientMessage(playerid, COLOR_WHITE2, string);
			format(string, sizeof(string), "Deposit: $%d",cashdeposit);
			SendClientMessage(playerid, COLOR_WHITE2, string);
			SendClientMessage(playerid, COLOR_WHITE2, "|-----------------------------------------|");
			format(string, sizeof(string), "New Balance: $%d", BankInfo[playerid][Cash]);
			SendClientMessage(playerid, COLOR_WHITE2, string);
			format(string, sizeof(string), "The latest deposited money was by %s ammount: $%d",sendername,cashdeposit);
			strmid(BankInfo[playerid][LastDepo],string,0,255,255);
			dini_Set(BankInfo[playerid][Filename],"LastDeposit",string);
			return 1;
		}
		return 1;
	}
