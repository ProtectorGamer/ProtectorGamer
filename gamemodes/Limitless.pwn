	if(strcmp(cmd, "/ammuname", true) == 0)
	{
        if (IsPlayerConnected(playerid))
	    {
            for(new b = 0; b < sizeof(BizzInfo); b++)
		    {
			    if(PlayerToPoint(2.0, playerid, BizzInfo[b][bEntranceX], BizzInfo[b][bEntranceY], BizzInfo[b][bEntranceZ]))
			    {
	                if (strmatch(BizzInfo[b][bOwner],Spielername(playerid)))
	                {
	                    new length = strlen(cmdtext);
	                    while ((idx < length) && (cmdtext[idx] <= ' '))
			            {
				            idx++;
			            }
		                new offset = idx;
			            new result[255];
			            while ((idx < length) && ((idx - offset) < (sizeof(result) - 1)))
			            {
		                    result[idx - offset] = cmdtext[idx];
  		                    idx++;
			            }
			            result[idx - offset] = EOS;
                        if(!strlen(result))
			            {
				            SendClientMessage(playerid, COLOR_WHITE2, "Function: {FFFFFF}/ammuname [Name]");
			            }
			            else
                        {
				            strmid(BizzInfo[b][bMessage], result, 0, 64, 255);
				            format(string, sizeof(string), "Your Name Name Has Been Seted To to %s",BizzInfo[b][bMessage]);
				            SendClientMessage(playerid, COLOR_WHITE2, string);
			            }
					}
				}
			}
		}
		return 1;
	}
	//-------------------------[Clubs Commands]-------------------------
	if(strcmp(cmd, "/drink", true) == 0)
	{
	    if(PlayerToPoint(5.0, playerid,499.9618,-20.6285,1000.6797) || PlayerToPoint(5.0, playerid,497.2571,-76.0136,998.7578) || PlayerToPoint(5.0, playerid,1215.4363,-13.3518,1000.9219))
	    {
	        new x_nr[256];
			x_nr = strtok(cmdtext, idx);
			if(!strlen(x_nr))
			{
			    SendClientMessage(playerid, COLOR_BROWN, "-------------------- Bar Drinks -----------------------");
			    SendClientMessage(playerid, COLOR_GREY, "Function: {FFFFFF}/drink [drinkname]");
				SendClientMessage(playerid, COLOR_WHITE2, "Water ($5), Sprunk($2) Zen(3$) Pepsi(4$) Cola(4$)");
				SendClientMessage(playerid, COLOR_WHITE2, "Beer ($6), Bourbon($8), Champagne($12)");
				SendClientMessage(playerid, COLOR_WHITE2, "Vodka ($16), Cristal($20) Teuquila(25$)");
				SendClientMessage(playerid, COLOR_BROWN, "--------------------------------------------------------");
				return 1;
			}
			if(PlayerToPoint(5.0, playerid,499.9618,-20.6285,1000.6797))
            {
			    if(strcmp(x_nr,"water",true) == 0)
			    {
				    Otman_TakePlayerMoney(playerid,5);
					SetPlayerSpecialAction(playerid,SPECIAL_ACTION_DRINK_SPRUNK); // Drinking in bar
                    ClubInfo[0][clTill] += 5;
	                ClubInfo[0][clProds] -= 1;
				}
				if(strcmp(x_nr,"Zen",true) == 0)
