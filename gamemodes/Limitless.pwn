	                    if(GetCreatorID(h)!=0)
	                    {
	                        if (strmatch(VehicleSystem[GetCreatorID(h)][owner],Spielername(playerid)))
	                        {
                                for(new i = 0; i < GetMaxPlayers(); i++)
	                            {
	                                if(IsPlayerConnected(i))
					                {
						                SetVehicleParamsForPlayer(h,i,0,1);
							        }
						        }
						        GetPlayerName(playerid, sendername, sizeof(sendername));
                                format(string, sizeof(string), "%s lock's the vehicle", sendername);
		                        ProxDetector(5.0, playerid, string, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
			                    SendClientMessage(playerid, COLOR_RED, "Vehicle locked");
			                    VehicleSystem[GetCreatorID(h)][Lock] = 1;
			                    SaveTool(GetCreatorID(h));
			                    new Float:pX, Float:pY, Float:pZ;
			                    GetPlayerPos(playerid,pX,pY,pZ);
				                PlayerPlaySound(playerid,1056,pX,pY,pZ);
