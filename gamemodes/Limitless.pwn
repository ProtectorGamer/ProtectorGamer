	if(strcmp(cmd, "/refuel", true) == 0)
	{
	    if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
        {
			for(new g = 0; g < sizeof(GZInfo); g++)
			{
				if(PlayerToPoint(3.0, playerid, GZInfo[g][gzFuelx], GZInfo[g][gzFuely], GZInfo[g][gzFuelz]))
				{
				    if(GZInfo[g][gzFuel] == 0)
					{
                        SendClientMessage(playerid,COLOR_RED,"[Station] Out of fuel !");
						return 1;
					}
                    GetPlayerName(playerid, sendername, sizeof(sendername));
			        SendClientMessage(playerid,COLOR_LIGHTRED,"[Station] Refueling The Vehicle Please Wait ...");
			        RefuelID[playerid] = GetPlayerVehicleID(playerid);
			        Refueling[playerid] = 1;
			        RefuelPrice[playerid] = GZInfo[g][gzPrice];
		            new FillUp = GasMax - Gas[GetPlayerVehicleID(playerid)];
		            GZInfo[g][gzFuel] -= FillUp;
		            TogglePlayerControllable(playerid, 0);
		            SetTimerEx("Fillup",RefuelWait, false,"i",playerid);
				    return 1;
				}
			}
		}
    	return 1;
	}
	if(strcmp(cmd, "/start", true) == 0)
	{
	    if(IsPlayerConnected(playerid))
