				                    return 1;
								}
							}
						}
					}
				}
			}
			if(strcmp(x_nr,"unlock",true) == 0)
	        {
                for(new h = 0;h<MAX_BUY_V;h++)
	            {
                    new Float:vX,Float:vY,Float:vZ;
                    GetVehiclePos(h,vX,vY,vZ);
		            if(PlayerToPoint(3.0, playerid, vX,vY,vZ))
		            {
	                    if(GetCreatorID(h)!=0)
	                    {
	                        if (strmatch(VehicleSystem[GetCreatorID(h)][owner],Spielername(playerid)))
	                        {
                                for(new i = 0; i < GetMaxPlayers(); i++)
	                            {
	                                if(IsPlayerConnected(i))
					                {
						                SetVehicleParamsForPlayer(h,i,0,0);
							        }
						        }
						        GetPlayerName(playerid, sendername, sizeof(sendername));
                                format(string, sizeof(string), "%s unlock's the vehicle", sendername);
		                        ProxDetector(5.0, playerid, string, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
			                    SendClientMessage(playerid, COLOR_GREEN, "Vehicle unlocked");
			                    VehicleSystem[GetCreatorID(h)][Lock] = 0;
			                    SaveTool(GetCreatorID(h));
			                    new Float:pX, Float:pY, Float:pZ;
			                    GetPlayerPos(playerid,pX,pY,pZ);
				                PlayerPlaySound(playerid,1056,pX,pY,pZ);
						    }
						    if(VehicleSystem[GetCreatorID(h)][Faction] != 0)
						    {
								if(PlayerInfo[playerid][pMember] == VehicleSystem[GetCreatorID(h)][Faction])
								{
                                    for(new i = 0; i < GetMaxPlayers(); i++)
	                                {
	                                    if(IsPlayerConnected(i))
					                    {
						                    SetVehicleParamsForPlayer(h,i,0,0);
							            }
						            }
						            GetPlayerName(playerid, sendername, sizeof(sendername));
                                    format(string, sizeof(string), "%s unlock's the vehicle", sendername);
		                            ProxDetector(5.0, playerid, string, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
			                        SendClientMessage(playerid, COLOR_GREEN, "Vehicle unlocked");
			                        VehicleSystem[GetCreatorID(h)][Lock] = 0;
			                        SaveTool(GetCreatorID(h));
			                        new Float:pX, Float:pY, Float:pZ;
			                        GetPlayerPos(playerid,pX,pY,pZ);
				                    PlayerPlaySound(playerid,1056,pX,pY,pZ);
								}
							}
							return 1;
					    }
					}
				}
			}
			if(strcmp(x_nr,"park",true) == 0)
	        {
                if(!IsPlayerInAnyVehicle(playerid))
		        {
		            return 1;
		        }
	            if(GetCreatorID(vehicleid)!=0)
	            {
	                if (strmatch(VehicleSystem[GetCreatorID(vehicleid)][owner],Spielername(playerid)))
	                {
                        new Float:vx,Float:vy,Float:vz,Float:va;
	                    GetVehiclePos(GetPlayerVehicleID(playerid),vx,vy,vz);
	                    GetVehicleZAngle(GetPlayerVehicleID(playerid),va);
	                    VehicleSystem[GetCreatorID(vehicleid)][carx]=vx;
	                    VehicleSystem[GetCreatorID(vehicleid)][cary]=vy;
	                    VehicleSystem[GetCreatorID(vehicleid)][carz]=vz;
	                    VehicleSystem[GetCreatorID(vehicleid)][cara]=va;
	                    SendClientMessage(playerid,COLOR_Milito,"||- You have parked your vehicle at this location -||");
	                    SaveTool(GetCreatorID(vehicleid));
 	                }
		        }
			}
			if(strcmp(x_nr,"alarm",true) == 0)
	        {
		        for(new h = 0;h<MAX_BUY_V;h++)
	            {
                    new Float:vX,Float:vY,Float:vZ;
                    GetVehiclePos(h,vX,vY,vZ);
		            if(PlayerToPoint(3.0, playerid, vX,vY,vZ))
		            {
	                    if(GetCreatorID(h)!=0)
	                    {
	                        if (strmatch(VehicleSystem[GetCreatorID(h)][owner],Spielername(playerid)))
	                        {
						        if(VehicleSystem[GetCreatorID(h)][HAlarm] == 0)
