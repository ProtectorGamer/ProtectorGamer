    if(strcmp(cmd, "/rentcar", true) == 0)
	{
        if(IsPlayerConnected(playerid))
		{
			if(GetPlayerVehicleID(playerid) >= 40 && GetPlayerVehicleID(playerid) <= 47)
			{
				if(GetPlayerVehicleID(playerid) >= 40 && GetPlayerVehicleID(playerid) <= 43)
				{
					if (Otman_GetPlayerMoney(playerid) >= CrentInfo[0][rcRentCost] && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
					{
					    Otman_TakePlayerMoney(playerid,CrentInfo[0][rcRentCost]);
					    CrentInfo[0][rcTill] += CrentInfo[0][rcRentCost];
					    RentedCar[playerid] = GetPlayerVehicleID(playerid);
					    PriveCar[playerid] = 0;
					    TogglePlayerControllable(playerid, 1);
					    SendClientMessage(playerid, COLOR_DARKGREEN, "You have successfuly rented this vehicle use /engine to turn it on");
					    PlayerPlaySound(playerid, 1054, 0.0, 0.0, 0.0);
					    return 1;
				    }
				}
				if(GetPlayerVehicleID(playerid) >= 44 && GetPlayerVehicleID(playerid) <= 47)
				{
                    if (Otman_GetPlayerMoney(playerid) >= CrentInfo[1][rcRentCost] && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
					{
					    Otman_TakePlayerMoney(playerid,CrentInfo[1][rcRentCost]);
					    CrentInfo[1][rcTill] += CrentInfo[1][rcRentCost];
					    RentedCar[playerid] = GetPlayerVehicleID(playerid);
					    PriveCar[playerid] = 0;
					    TogglePlayerControllable(playerid, 1);
					    SendClientMessage(playerid, COLOR_DARKGREEN, "You have successfuly rented this vehicle use /engine to turn it on");
					    PlayerPlaySound(playerid, 1054, 0.0, 0.0, 0.0);
					    return 1;
