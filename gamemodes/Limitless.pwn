			format(loginstring,sizeof(loginstring),"Invalid Password!\nPlease enter the correct password:",loginname);
			ShowPlayerDialog(playerid,12347,DIALOG_STYLE_PASSWORD,"Login",loginstring,"Login","Cancel");
	        fclose(UserFile);
	        LogTries[playerid] += 1;
	        if(LogTries[playerid] == 5) { Ban(playerid); }
	        return 1;
		}
		//TempBanCheck(playerid);
		new filebanned[100];
		format(filebanned, sizeof(filebanned),"LG/Accounts/BannedPlayers/%s.ban",playername2);
		if(dini_Exists(filebanned))
        {
            new pName[MAX_PLAYER_NAME];
            new string[256];
            GetPlayerName(playerid, pName, sizeof(pName));
            format(string,256,"Database: {FFFFFF}%s has been banned. Reason: Logging into a banned account!",pName);
            SendClientMessageToAll(COLOR_RED,string);
            Kick(playerid);
	    }
		TextDrawDestroy(Textdrawz4[playerid]);
		PlayerInfo[playerid][pAdjustable] = 0;
		if(PlayerInfo[playerid][pReg] == 0)
		{
			PlayerInfo[playerid][pLevel] = 1;
			PlayerInfo[playerid][pInt] = 1;
			PlayerInfo[playerid][pAccount] = 500;
			PlayerInfo[playerid][pReg] = 1;
			PlayerInfo[playerid][pAge] = 18;
			PlayerInfo[playerid][pOrigin] = 1;
			PlayerInfo[playerid][pTut] = 0;
			if(Gender[playerid] == 1) { PlayerInfo[playerid][pSex] = 1; PlayerInfo[playerid][pModel] = 98; }
			if(Gender[playerid] == 2) { PlayerInfo[playerid][pSex] = 2; PlayerInfo[playerid][pModel] = 93; }
			Otman_GivePlayerMoney(playerid, 5000);
			UpdatePlayerInfo(playerid);
		}
		printf("%s has connected!",playername2);
		if (PlayerInfo[playerid][pDonateRank] > 0)
		{
			SendClientMessage(playerid, COLOR_PINKY,"Details: You are a Premium Account user");
		}
		if(!gPlayerAnimLibsPreloaded[playerid])
	    {
    	    PreloadAnimLib(playerid,"PED");
            PreloadAnimLib(playerid,"MEDIC");
   		    PreloadAnimLib(playerid,"BEACH");
   		    PreloadAnimLib(playerid,"SWORD");
   		    PreloadAnimLib(playerid,"SMOKING");
    	    PreloadAnimLib(playerid,"FOOD");
    	    PreloadAnimLib(playerid,"ON_LOOKERS");
    	    PreloadAnimLib(playerid,"DEALER");
    	    PreloadAnimLib(playerid,"KISSING");
    	    PreloadAnimLib(playerid,"GANGS");
		    PreloadAnimLib(playerid,"CRACK");
		    PreloadAnimLib(playerid,"CARRY");
		    PreloadAnimLib(playerid,"COP_AMBIENT");
		    PreloadAnimLib(playerid,"PARK");
		    PreloadAnimLib(playerid,"INT_HOUSE");
		    PreloadAnimLib(playerid,"FOOD");
		    PreloadAnimLib(playerid,"BASEBALL");
		    gPlayerAnimLibsPreloaded[playerid] = 1;
		}
		ClearChatbox(playerid, 8);
		SendClientMessage(playerid, COLOR_PINKY, "=================================================");
		format(string2, sizeof(string2), "Welcome to Limitless Gaming, %s.",playername2);
		SendClientMessage(playerid, COLOR_WHITE2,string2);
		SetSpawnInfo(playerid, 1, PlayerInfo[playerid][pModel], PlayerInfo[playerid][pPosX], PlayerInfo[playerid][pPosY], PlayerInfo[playerid][pPosZ], 1.0, -1, -1, -1, -1, -1, -1);
		if(PlayerInfo[playerid][pHandsGun1] != 0 || PlayerInfo[playerid][pHandsGun2] != 0 || PlayerInfo[playerid][pHandsGun3] != 0 || PlayerInfo[playerid][pHandsGun4] != 0)
		{
			SendClientMessage(playerid,COLOR_WHITE2,"Note: {FFFFFF}Use /getweps to spawn your weapons");
		}
		Logged[playerid] = 1;
		ClearChatbox(playerid, 3);
		TogglePlayerSpectating(playerid,0);
		MoneyDetectionTimer[playerid] = SetTimerEx("MoneyDetection",5000, true, "i", playerid);
        WeaponDetectionTimer[playerid] = SetTimerEx("WeaponDetection",7000, true, "i", playerid);
        pickupstimer[playerid] = SetTimerEx("CustomPickups",2000, true, "i", playerid);
        Otman_GivePlayerMoney(playerid,PlayerInfo[playerid][pMoney]);
	}
	return 1;
}

public AmmoUpdate(playerid)
{
	if(PlayerInfo[playerid][pHandsGun1] != 0)
	{
		new aw1,aa1;
		new slot1 = GetPlayerWeaponSlotID(PlayerInfo[playerid][pHandsGun1]);
        GetPlayerWeaponData(playerid,slot1, aw1, aa1);
        if(PlayerInfo[playerid][pHandsGun1] == aw1)
        {
            PlayerInfo[playerid][pHandsBullets1] = aa1;
	    }
	}
	if(PlayerInfo[playerid][pHandsGun2] != 0)
	{
        new aw2,aa2;
        new slot2 = GetPlayerWeaponSlotID(PlayerInfo[playerid][pHandsGun2]);
        GetPlayerWeaponData(playerid,slot2, aw2, aa2);
        if(PlayerInfo[playerid][pHandsGun2] == aw2)
        {
            PlayerInfo[playerid][pHandsBullets2] = aa2;
	    }
	}
	if(PlayerInfo[playerid][pHandsGun3] != 0)
	{
        new aw3,aa3;
        new slot3 = GetPlayerWeaponSlotID(PlayerInfo[playerid][pHandsGun3]);
        GetPlayerWeaponData(playerid,slot3, aw3, aa3);
        if(PlayerInfo[playerid][pHandsGun3] == aw3)
        {
            PlayerInfo[playerid][pHandsBullets3] = aa3;
	    }
	}
	if(PlayerInfo[playerid][pHandsGun4] != 0)
	{
        new aw4,aa4;
        new slot4 = GetPlayerWeaponSlotID(PlayerInfo[playerid][pHandsGun4]);
        GetPlayerWeaponData(playerid,slot4, aw4, aa4);
        if(PlayerInfo[playerid][pHandsGun4] == aw4)
        {
            PlayerInfo[playerid][pHandsBullets4] = aa4;
	    }
	}
	if(PlayerInfo[playerid][pHandsBullets1] == 0)
	{
        PlayerInfo[playerid][pHandsGun1] = 0;
	}
	if(PlayerInfo[playerid][pHandsBullets2] == 0)
	{
        PlayerInfo[playerid][pHandsGun2] = 0;
	}
	if(PlayerInfo[playerid][pHandsBullets3] == 0)
	{
        PlayerInfo[playerid][pHandsGun3] = 0;
	}
	if(PlayerInfo[playerid][pHandsBullets4] == 0)
	{
        PlayerInfo[playerid][pHandsGun4] = 0;
	}
}

public UpdatePlayerInfo(playerid)
{
    if(PlayerInfo[playerid][pBullets1] == 0)
    {
        new text[64];
        text = "Empty";
        PlayerInfo[playerid][pGuns1Name] = text;
        PlayerInfo[playerid][pGuns1] = 0;
    }
    if(PlayerInfo[playerid][pBullets2] == 0)
    {
        new text[64];
        text = "Empty";
        PlayerInfo[playerid][pGuns2Name] = text;
        PlayerInfo[playerid][pGuns2] = 0;
    }
    if(PlayerInfo[playerid][pBullets3] == 0)
    {
        new text[64];
        text = "Empty";
        PlayerInfo[playerid][pGuns3Name] = text;
        PlayerInfo[playerid][pGuns3] = 0;
