			if (!PlayerToPoint(5.0, playerid,2308.7505,-13.2901,26.7422))
	        {
	            SendClientMessage(playerid, COLOR_GREY, "You are not at the Bank !");
	            return 1;
	        }
	        if(BankLogin[playerid] != 1)
	        {
                SendClientMessage(playerid, COLOR_GREY, "Please login first to your bank account by typing '/bank login'");
	            return 1;
			}
			tmp = strtok(cmdtext, idx);
			if(!strlen(tmp))
			{
				SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/withdraw [amount]");
				format(string, sizeof(string), "You Have $%d in your account.", BankInfo[playerid][Cash]);
				SendClientMessage(playerid, COLOR_GRAD3, string);
				return 1;
			}
			new cashdeposit = strval(tmp);
			if(!strlen(tmp))
			{
				SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/withdraw [amount]");
				format(string, sizeof(string), "You Have $%d in your account.", BankInfo[playerid][Cash]);
				SendClientMessage(playerid, COLOR_GRAD3, string);
				return 1;
			}
			if (cashdeposit > BankInfo[playerid][Cash] || cashdeposit < 0)
			{
				SendClientMessage(playerid, COLOR_GRAD2, "Please type the presize ammount");
				return 1;
			}
			GetPlayerName(playerid, sendername, sizeof(sendername));
			Otman_GivePlayerMoney(playerid,cashdeposit);
			BankInfo[playerid][Cash] -= cashdeposit;
			dini_IntSet(BankInfo[playerid][Filename],"Cash",BankInfo[playerid][Cash]);
            format(string, sizeof(string), "You Have Withdrawn $%d from then account Total: $%d ", cashdeposit,BankInfo[playerid][Cash]);
			SendClientMessage(playerid, COLOR_YELLOW, string);
			format(string, sizeof(string), "The latest withdrawen money was by %s ammount: $%d",sendername,cashdeposit);
			strmid(BankInfo[playerid][LastWith],string,0,255,255);
			dini_Set(BankInfo[playerid][Filename],"LastWithdraw",string);
			return 1;
		}
		return 1;
	}
	if(strcmp(cmd, "/deposit", true) == 0)
	{
	    if(IsPlayerConnected(playerid))
