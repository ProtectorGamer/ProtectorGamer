			    {
				    SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/fdeposit [amount]");
				    format(string, sizeof(string), "You Have $%d in your faction account.", HQInfo[h][hqBank]);
				    SendClientMessage(playerid, COLOR_GRAD3, string);
				    return 1;
