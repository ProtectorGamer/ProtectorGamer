			        new offset = idx;
			        new result[128];
			        while ((idx < length) && ((idx - offset) < (sizeof(result) - 1)))
			        {
				        result[idx - offset] = cmdtext[idx];
				        idx++;
			        }
			        result[idx - offset] = EOS;
			        if(!strlen(result))
			        {
				        SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/(/ad)vertise [advert text]");
				        return 1;
			        }
			        if(ADInfo[h][adLock] == 1)
			        {
                        SendClientMessage(playerid, COLOR_GRAD2, "The company is closed");
				        return 1;
