public Killanim(playerid)
{
    SetPlayerSpecialAction(playerid,SPECIAL_ACTION_STOPUSECELLPHONE);
    return 1;
}

public SendAdminMessage(color, string[])
{
    for(new i = 0; i < GetMaxPlayers(); i++)
	{
		if(IsPlayerConnected(i))
		{
		    if(PlayerInfo[i][pAdmin] >= 1)
		    {
				SendClientMessage(i, color, string);
			}
		}
	}
	return 1;
}

public heal(playerid)
{
    if(healthpack[playerid] == 1)
    {
       new Float:health[MAX_PLAYERS];
       new sendername[MAX_PLAYER_NAME];
       new string[256];
       GetPlayerHealth(playerid, health[playerid]);
       if(health[playerid] < 100)
       {
       	   SetPlayerHealth(playerid, health[playerid]+1);
       }
       if(health[playerid] == 100)
       {
           KillTimer(healtimer[playerid]);
           healthpack[playerid] = 0;
           TogglePlayerControllable(playerid, 1);
           GetPlayerName(playerid, sendername, sizeof(sendername));
           format(string, sizeof(string), "%s has been healed and cured", sendername);
		   ProxDetector(15.0, playerid, string, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
		   return 1;
       }
    }
    return 1;
}

public mheal(playerid)
{
    new Float:health[MAX_PLAYERS];
    new sendername[MAX_PLAYER_NAME];
    new string[256];
    GetPlayerHealth(playerid, health[playerid]);
    if(health[playerid] < 100)
    {
	    SetPlayerHealth(playerid, health[playerid]+1);
    }
    if(health[playerid] == 100)
    {
        KillTimer(healtimer[playerid]);
        TogglePlayerControllable(playerid, 1);
        GetPlayerName(playerid, sendername, sizeof(sendername));
        format(string, sizeof(string), "%s has been healed and cured", sendername);
	    ProxDetector(10.0, playerid, string, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
	    return 1;
    }
    return 1;
}

