public UpdateRank(playerid)//THIS UPDATES THE PLAYERS SKIN/NAME COLOR WITHOUT RESPAWNING/KILLING THE PLAYER
{
	if(IsPlayerConnected(playerid))
	{
	    if (PlayerInfo[playerid][pMember] == Police || PlayerInfo[playerid][pLeader] == Police)//Police Force spawn
        {
			if(PlayerInfo[playerid][pRank] == 1)
   			{
			SetPlayerColor(playerid,COLOR_LVPD);
			SetPlayerSkin(playerid,265);
