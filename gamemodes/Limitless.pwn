public Fillup(playerid)
{
    new string[256];
    new sendername[MAX_PLAYER_NAME];
    new VID = RefuelID[playerid];
    new FillUp = GasMax - Gas[VID];
    if(Refueling[playerid] == 1)
    {
        if(Otman_GetPlayerMoney(playerid) >= FillUp+1)
		{
		    Gas[VID] += FillUp;
		    GetPlayerName(playerid, sendername, sizeof(sendername));
            format(string,sizeof(string),"%s has refilled his vehicle for $%d",sendername,FillUp);
            ProxDetector(10.0, playerid, string, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
		    Otman_TakePlayerMoney(playerid,RefuelPrice[playerid]);
		    RefuelID[playerid] = 0;
		    RefuelPrice[playerid] = 0;
		    Refueling[playerid] = 0;
		    TogglePlayerControllable(playerid, 1);
		}
 	    else
 	    {
 	        format(string,sizeof(string),"Not enough money to refill, it costs $%d to fill your vehicle",RefuelPrice[playerid]);
		    SendClientMessage(playerid,COLOR_LIGHTBLUE,string);
		    RefuelID[playerid] = 0;
		    RefuelPrice[playerid] = 0;
		    Refueling[playerid] = 0;
		}
	}
	return 1;
}

public Tutorial()
{
    for(new i = 0; i < GetMaxPlayers(); i++)
	{
	    if(IsPlayerConnected(i))
	    {
	        if(TutTime[i] >= 1)
			{
			    TutTime[i] += 1;
			    if(TutTime[i] == 3)
			    {
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "Foreword");
			        SendClientMessage(i, COLOR_WHITE2, "Hello and welcome to Limitless Gaming.");
			        SendClientMessage(i, COLOR_WHITE2, "We've taken recognition that you're a new player here. We'd like you to endure a 2 minute tutorial.");
			        SendClientMessage(i, COLOR_WHITE2, "To avoid questions at a later date, be sure to pay attention to the tutorial.");
			    }
			    else if(TutTime[i] == 10)
			    {
                    SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "First and foremost...");
			    }
			    else if(TutTime[i] == 12)
			    {
			        SendClientMessage(i, COLOR_WHITE2, "Limmitless Gaming is a Roleplay server. Roleplay is a game genre where the players assume the role of a fictional");
			        SendClientMessage(i, COLOR_WHITE2, "character. In our server, your name is your identity, and must be in the format");
			        SendClientMessage(i, COLOR_WHITE2, "Firstname_Lastname. It can be anything you want, too! As long as it's realistic and");
			        SendClientMessage(i, COLOR_WHITE2, "not a celebrity name. An example of a valid name is: 'Leonardo_Montana'.");
			    }
			    else if(TutTime[i] == 20)
			    {
                    SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "Debrief");
			    }
			    else if(TutTime[i] == 25)
			    {
			        SendClientMessage(i, COLOR_WHITE2, "Limitless Gaming has high expectations. You're to role-play at all times and");
			        SendClientMessage(i, COLOR_WHITE2, "to maintain a realistic atmosphere.");
			        SendClientMessage(i, COLOR_WHITE2, "Despite server organisations/factions, there is no limit as to what you can role-play,");
			        SendClientMessage(i, COLOR_WHITE2, "providing it follows the server rules.");
			    }
			    else if(TutTime[i] == 42)
			    {
                    SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "In Character v. Out of Character");
			    }
			    else if(TutTime[i] == 44)
			    {
			        SendClientMessage(i, COLOR_WHITE2, "In Character (IC) and Out of Character (OOC) is fundamental to good roleplaying!");
			        SendClientMessage(i, COLOR_WHITE2, "OOC refers to you, the player, talking about irrelevant or off topic things.");
			        SendClientMessage(i, COLOR_WHITE2, "To talk in OOC to each other, use /o, /b and /pm. IC refers to your characters");
			        SendClientMessage(i, COLOR_WHITE2, "actions - Be sure to understand the difference between OOC and IC!");
			    }
			    else if(TutTime[i] == 64)
			    {
                    SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "Metagaming and Powergaming");
			    }
			    else if(TutTime[i] == 66)
			    {
			        SendClientMessage(i, COLOR_WHITE2, "There are a number of roleplay terms that you will need to understand, such as 'Metagaming'");
			        SendClientMessage(i, COLOR_WHITE2, "(using OOC information in an IC situation), or 'Powergaming' (declaring un-realistic actions, such as 'Superman' actions)");
			        SendClientMessage(i, COLOR_WHITE2, "to know will be there. We don't like people metagaming or powergaming, so please don't do it!");
			    }
			    else if(TutTime[i] == 86)
			    {
                    SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "Driver drive-by");
			    }
			    else if(TutTime[i] == 88)
			    {
			        SendClientMessage(i, COLOR_WHITE2, "We do not permit the driver of a vehicle to shoot from the drivers seat.");
			        SendClientMessage(i, COLOR_WHITE2, "It's a generic, simple, role-playing rule as it declares a disadvantage to those on foot.");
			        SendClientMessage(i, COLOR_WHITE2, "Committing this will simply result in administrative punishment.");
			    }
			    else if(TutTime[i] == 98)
			    {
                    SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "English v. Non-English");
			    }
			    else if(TutTime[i] == 102)
			    {
			        SendClientMessage(i, COLOR_WHITE2, "In /b, /o or any other chat, we ask that you please use English.");
			        SendClientMessage(i, COLOR_WHITE2, "If you role-play a foreign character, you can role-play with an accent.");
			        SendClientMessage(i, COLOR_WHITE2, "If you wish to speak in your first language (Non-English), then please use /pm!");
			    }
			    else if(TutTime[i] == 112)
			    {
                    SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "Conclusion");
			    }
			    else if(TutTime[i] == 115)
			    {
			        SendClientMessage(i, COLOR_WHITE2, "That's it! Be sure to bare in mind our rules at all times.");
			        SendClientMessage(i, COLOR_WHITE2, "Just keep them lodged in the back of your mind, and you'll be fine!");
			        SendClientMessage(i, COLOR_WHITE2, "Greetings from us, the Limitless Gaming community.");
			    }
			    else if(TutTime[i] == 122)
			    {
			        SendClientMessage(i, COLOR_LIGHTRED, "Please give the database a moment to stream the objects for you.");
			    }
			    else if(TutTime[i] == 128)
			    {
                    ClearChatbox(i, 10);
			        TutTime[i] = 0;
			        PlayerInfo[i][pTut] = 2;
	                TogglePlayerControllable(i, 0);
	                UpdatePlayerInfo(i);
	                SpawnPlayer(i);
			        /*TutQuest[i] = 1;
			        SendClientMessage(i, COLOR_PINKY, "");
			        SendClientMessage(i, COLOR_PINKY, "What does the term RP stand for?");
			        SendClientMessage(i,COLOR_WHITE2,"[A]: Real Playing");
                    SendClientMessage(i,COLOR_WHITE2,"[B]: Role Playing");
                    SendClientMessage(i,COLOR_WHITE2,"[C]: Record Playing");
                    SendClientMessage(i, COLOR_LIGHTRED, "Type the right answer (A, B, C,) You have one chance !");
	                PlayerPlaySound(i, 1056, 0.0, 0.0, 0.0);*/
			        return 0;
				}
			}
		}
	}
	return 1;
}

