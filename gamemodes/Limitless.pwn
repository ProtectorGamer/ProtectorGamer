    if(strcmp(cmd,"/getdrugs",true)==0)
    {
       if(IsPlayerConnected(playerid))
	   {
	      if(PlayerInfo[playerid][pDealerDrugs] != 0)
		  {
		      format(string, sizeof(string), "Info: You have %d grams in hands go sell it", PlayerInfo[playerid][pDealerDrugs]);
		      SendClientMessage(playerid, COLOR_PINKY, string);
		      return 1;
		  }
		  new tel = 500;
	      new price;
	      new ammount;
	      tmp = strtok(cmdtext, idx);
		  if(!strlen(tmp))
		  {
			  SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/getdrugs [amount]");
			  return 1;
		  }
		  ammount = strval(tmp);
		  if (PlayerInfo[playerid][pJob] == 4 && PlayerToPoint(3.0, playerid, 950.0308,2144.1860,1011.0199))
		  {
		      price = ammount * tel;
			  if(Otman_GetPlayerMoney(playerid) > price)
			  {
			      format(string, sizeof(string), "<< You bought %d grams for $%d >>", ammount, price);
				  SendClientMessage(playerid, COLOR_LIGHTRED, string);
			      Otman_TakePlayerMoney(playerid, price);
				  PlayerInfo[playerid][pDealerDrugs] += ammount;
				  return 1;
		      }
		  }
		  else
	      {
			  SendClientMessage(playerid, COLOR_RED, "Error: You Are not a Drug Dealer, or you are not at the Drugs factory");
			  return 1;
		  }
	   }
	   return 1;
	}
