public OnGameModeInit()
{
    OtmanAMX();
    if (!fexist("LG/Accounts/TempBanned/TempBans.ban"))
	{
		new File:open = fopen("LG/Accounts/TempBanned/TempBans.ban",io_write);
		if (open) fclose(open);
	}
    djson_GameModeInit();
    LoadData();
    LoadDealer();
    GsBizz();
    ShpBizz();
    LoadHQ();
    LoadHouses();
    LoadRentCar();
    LoadClubs();
    LoadAd();
    LoadPhone();
    LoadGZ();
// 	Seifader_OnInit();
    new string[MAX_PLAYER_NAME];
    new string1[MAX_PLAYER_NAME];
	//Mode Name
	for(new c=0;c<CAR_AMOUNT;c++)
	{
		Gas[c] = GasMax;
	}
	SetGameModeText("Limitless 1.0.0");
	//The Allowed Functions
	EnableStuntBonusForAll(0);
	SetNameTagDrawDistance(20);
	AllowAdminTeleport(1);
	AllowInteriorWeapons(0);
	ShowPlayerMarkers(0);
	DisableInteriorEnterExits();
	//------Setserver time-------
	gettime(ghour, gminute, gsecond);
	FixHour(ghour);
	ghour = shifthour;
	if(!realtime)
	{
		SetWorldTime(wtime);
	}
	if (realtime)
	{
		new tmphour;
		new tmpminute;
		new tmpsecond;
		gettime(tmphour, tmpminute, tmpsecond);
		FixHour(tmphour);
		tmphour = shifthour;
		SetWorldTime(tmphour);
	}
	//------TextDraws--------
	/*//TextDraw0
    format(string,sizeof(string),"ViceCity");
    Textdraw0 = TextDrawCreate(577.000000,5.000000, string);
	TextDrawAlignment(Textdraw0,2);
	TextDrawLetterSize(Textdraw0,0.5,2);
	TextDrawFont(Textdraw0,0);
