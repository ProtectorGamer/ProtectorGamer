public OnPlayerPickUpPickup(playerid, pickupid)
{
	new string[255];
    if(pickupid == Checkmoney)
    {
		if(PlayerInfo[playerid][pAccount] >= 500)
		{
			Otman_GivePlayerMoney(playerid,PlayerInfo[playerid][pAccount]);
			PlayerPlaySound(playerid, 1054, 0.0, 0.0, 0.0);
			format(string, sizeof(string), "Details: You have picked up your paycheck $%d", PlayerInfo[playerid][pAccount]);
			SendClientMessage(playerid,0x078301FF,string);
			SendClientMessage(playerid,COLOR_GREY,"You can save your money by creating a bank account '/bank create' or login '/bank login'");
			PlayerInfo[playerid][pAccount] = 0;
			UpdatePlayerInfo(playerid);
		}
	}
	if(pickupid == Newclothes)
	{
        SendClientMessage(playerid,COLOR_LIGHTRED,"Note: {FFFFFF}Hello there, you can change your clothes by typing '/changeclothes'");
	}
	return 1;
}

