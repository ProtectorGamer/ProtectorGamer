	if(strcmp(cmd, "/sellcar", true) == 0)
	{
	    if(Logged[playerid] == 1)
	    {
		    if(PlayerInfo[playerid][pJob] != 5)
		    {
				SendClientMessage(playerid, COLOR_GREY, "You are not a car jacker");
				return 1;
		    }
		    if(PlayerInfo[playerid][pCarTime] != 0)
		    {
                SendClientMessage(playerid, COLOR_GREY, "Details: You will have to wait a bit longer untill the next drop");
				return 1;
			}
		    if(IsPlayerInAnyVehicle(playerid))
		    {
		        if(GetCreatorID(vehicleid) == 0)
	            {
		            new randpay = 100 + random(600);
			        Otman_GivePlayerMoney(playerid,randpay);
			        new randtime = 200 + random(300);
		     	    PlayerInfo[playerid][pCarTime] = randtime;
			        format(string, sizeof(string), "Info: You sold a car for $%d, your reload time is %d minutes",randpay,randtime/60);
			        SendClientMessage(playerid, COLOR_LIGHTBLUE, string);
			        GameTextForPlayer(playerid, "~y~Sold the car ~n~~g~+5 Exp", 3000, 1);
			        PlayerPlaySound(playerid, 1056, 0.0, 0.0, 0.0);
			        DropCarTimer[playerid] = SetTimerEx("JackerTimer", PlayerInfo[playerid][pCarTime]*1000, false, "i", playerid);
			        PlayerInfo[playerid][pJobExp] += 5;
			        JobPoint[playerid] = 0;
		            DisablePlayerCheckpoint(playerid);
		            SetVehicleToRespawn(GetPlayerVehicleID(playerid));
				}
				else {
				SendClientMessage(playerid, COLOR_GREY, "Details: You can not sell ownable vehicles !");
				return 1; }
			}
		}
		return 1;
	}
	if(strcmp(cmd, "/selldrugs", true) == 0)
	{
	    if(IsPlayerConnected(playerid))
	    {
		    if(PlayerInfo[playerid][pJob] != 4)
		    {
				SendClientMessage(playerid, COLOR_GREY, "You are not a Drugs Dealer!");
				return 1;
		    }
			tmp = strtok(cmdtext, idx);
			if(!strlen(tmp))
			{
				SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/selldrugs [ID or Name/Part of name] [ammount]");
				return 1;
			}
			new playa;
			new needed;
			playa = ReturnUser(tmp);
			tmp = strtok(cmdtext, idx);
			if(!strlen(tmp)) { return 1; }
			needed = strval(tmp);
			if(needed < 1 || needed > 10) { SendClientMessage(playerid, COLOR_GREY, "Grams not lower then 1, or above 10!"); return 1; }
			tmp = strtok(cmdtext, idx);
			if(needed > PlayerInfo[playerid][pDealerDrugs]) { SendClientMessage(playerid, COLOR_GREY, "You dont have that much Drugs with you !"); return 1; }
			if(IsPlayerConnected(playa))
			{
			    if(playa != INVALID_PLAYER_ID)
			    {
					if (ProxDetectorS(8.0, playerid, playa))
					{
					    if(playa == playerid)
					    {
					        SendClientMessage(playerid, COLOR_GREY, "Cant sell to yourself!");
					        return 1;
					    }
					    GetPlayerName(playa, giveplayer, sizeof(giveplayer));
						GetPlayerName(playerid, sendername, sizeof(sendername));
					    format(string, sizeof(string), "Info: You Have Sold %d Gram's To %s",needed, giveplayer);
						SendClientMessage(playerid, COLOR_LIGHTRED, string);
						format(string, sizeof(string), "You Have received %d Gram's From %s",needed, sendername);
						SendClientMessage(playa, COLOR_LIGHTRED, string);
						ApplyAnimation(playerid, "DEALER", "DEALER_DEAL", 4.0, 0, 0, 0, 0, 0);
						PlayerInfo[playa][pDrugs] += needed;
						PlayerInfo[playerid][pDealerDrugs] -= needed;
					}
					else
					{
					    SendClientMessage(playerid, COLOR_GREY, "The given player is not near enough to you.");
					}
				}
			}
			else
			{
			    SendClientMessage(playerid, COLOR_GREY, "The specified player is currently not ingame.");
			}
		}
		return 1;
	}
	if(strcmp(cmd,"/Hug",true)==0)
    {
       if(IsPlayerConnected(playerid))
	   {
	      tmp = strtok(cmdtext, idx);
		  if(!strlen(tmp))
		  {
			  SendClientMessage(playerid, COLOR_RED, "Correct: /Hug [PlayerID]");
			  return 1;
		  }
	      new playa;
	      playa = ReturnUser(tmp);
		  if(IsPlayerConnected(playa))
		  {
		     if(playa != INVALID_PLAYER_ID)
	         {
			    if(ProxDetectorS(1.0, playerid, playa))
			    {
			        GetPlayerName(playa, giveplayer, sizeof(giveplayer));
				    GetPlayerName(playerid, sendername, sizeof(sendername));
					format(string, sizeof(string), "Details: You Have Offered %s A Hug", giveplayer);
				    SendClientMessage(playerid, COLOR_PROMOTE, string);
				    format(string, sizeof(string), "[HUG] %s is offering you a hug type /yes to accept or /no to reject", sendername);
				    SendClientMessage(playa, COLOR_PROMOTE, string);
				    HugsOffer[playa] = playerid;
				    return 1;
			    }
			 }
			 else
			 {
			    SendClientMessage(playerid, COLOR_GREY, "That player is offline");
			 }
		  }
	   }
