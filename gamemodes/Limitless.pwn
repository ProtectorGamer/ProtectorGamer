public OnPlayerDisconnect(playerid, reason)
{
    UpdatePlayerInfo(playerid);
    new dname[MAX_PLAYER_NAME];
    new string[200];
    GetPlayerName(playerid, dname, sizeof(dname));
    switch(reason)
    {
        case 0: format(string, sizeof(string), "%s Has left the server (Crashed)",dname);
        case 1: format(string, sizeof(string), "%s Has left the server (Quit)",dname);
        case 2: format(string, sizeof(string), "%s Has left the server (Kicked)",dname);
    }
    JoinLeaveOff(COLOR_GREY,string);
    if(GotHit[playerid] > 0)
	{
	    if(GetChased[playerid] < 999)
	    {
	        if(IsPlayerConnected(GetChased[playerid]))
	        {
	        	SendClientMessage(GetChased[playerid], COLOR_YELLOW, "Your Hit has left the server.");
	            GoChase[GetChased[playerid]] = 999;
			}
	    }
	}
	if(RentedCar[playerid] != 0)
	{
        SetVehicleToRespawn(RentedCar[playerid]);
	    RentedCar[playerid] = 0;
	}
	for(new i2=0;i2<MAX_VEHICLES;i2++)
	{
	    if(lockedcar[playerid][i2] == 1)
		{
			for(new i=0;i<GetMaxPlayers();i++)
			{
  				SetVehicleParamsForPlayer(i2,i, 0, 0);
			}
		}
        lockedcar[playerid][i2] = 0;
        lockedveh[i2] = 0;
        KillTimer(unlockcartimer[playerid]);
	}
    IsSpeeding[playerid] = false;
    KillTimer(playerspeedtimer[playerid]);
    KillTimer(CrashTimer[playerid]);
	KillTimer(WeaponDetectionTimer[playerid]);
	KillTimer(MoneyDetectionTimer[playerid]);
	KillTimer(pickupstimer[playerid]);
	KillTimer(AmmoTimer[playerid]);
	KillTimer(TaxiCounterTimer[playerid]);
	KillTimer(DieTime[playerid]);
	Logged[playerid] = 0;
	DieTime[playerid] = 0;
	//Seifader_OnPlayerDisconnect(playerid);
	Seifader_OnExit();
	Otman_OnPlayerDisconnect(playerid, reason);
	return 1;
}

public OnPlayerSpawn(playerid)
{
	if(Logged[playerid] == 0)
	{
        SendClientMessage(playerid, COLOR_RED, "You Need to Login First To Spawn [kicked]");
        Kick(playerid);
 	}
 	if(PlayerDead[playerid] == 1)
 	{
        PlayerDead[playerid] = 0;
	}
 	Otman_OnPlayerSpawn(playerid);
 	//TextDrawShowForPlayer(playerid, Textdraw0);
    //TextDrawShowForPlayer(playerid, Textdraw1);
    if(PlayerInfo[playerid][pMember] == 0)
    {
        if(PlayerInfo[playerid][pTut] == 0)
        {
            SetPlayerPos(playerid, 1686.0055,-2238.4497,13.5469); // Tutorial starts LS Airport
            SetPlayerFacingAngle(playerid,179.9150);
            SetPlayerCameraPos(playerid, 1685.5326,-2253.0974,15.3937);
            SetPlayerCameraLookAt(playerid, 1686.0055,-2238.4497,13.5469);
            SetPlayerSkin(playerid, PlayerInfo[playerid][pModel]);
            SetPlayerColor(playerid,COLOR_WHITE);
            SetPlayerInterior(playerid,0);
            PlayerInfo[playerid][pInt] = 0;
            TogglePlayerControllable(playerid, 0);
            TutTime[playerid] = 1;
            UpdatePlayerInfo(playerid);
		}
		else if(PlayerInfo[playerid][pTut] == 1)
        {
			if(PlaneSpawn[playerid] == 1)
			{
                SetPlayerVirtualWorld(playerid,0);
                SetPlayerPos(playerid, 1685.8019,-2238.4919,13.5469);
                SetPlayerFacingAngle(playerid,179.9150); // NoobSpawn LS Airport
                SetPlayerSkin(playerid, PlayerInfo[playerid][pModel]);
                Freezed[playerid] = 0;
                SetPlayerInterior(playerid,0);
                PlayerInfo[playerid][pInt] = 0;
                SetPlayerColor(playerid,COLOR_WHITE);
                TogglePlayerControllable(playerid, 1);
                UpdatePlayerInfo(playerid);
                LoopingAnim(playerid,"PED","WALK_civi",4.1,1,1,1,1,1);
                gPlayerUsingLoopingAnim[playerid] = 2;
                SetTimerEx("WalkTimer",6000, false,"i",playerid);
                UpdatePlayerInfo(playerid);
			}
			else
			{
                SetPlayerPos(playerid, 1685.8019,-2238.4919,13.5469);
                SetPlayerFacingAngle(playerid,179.9150); // NoobSpawn LS Airport
                SetPlayerSkin(playerid, PlayerInfo[playerid][pModel]);
                SetPlayerInterior(playerid,0);
                PlayerInfo[playerid][pInt] = 0;
                SetPlayerColor(playerid,COLOR_WHITE);
                TogglePlayerControllable(playerid, 1);
                UpdatePlayerInfo(playerid);
			}
        }
		else if(PlayerInfo[playerid][pTut] == 2)
        {
			SetPlayerVirtualWorld(playerid,playerid);
            SetPlayerPos(playerid,2.7766,29.7590,1199.6012);
            SetPlayerFacingAngle(playerid,178.1200);
            LoopingAnim(playerid,"ped", "SEAT_idle", 4.0, 1, 0, 0, 0, 0);
            Freezed[playerid] = 1;
            SetPlayerInterior(playerid,1);
            SetPlayerColor(playerid,COLOR_WHITE);
            SetPlayerSkin(playerid,PlayerInfo[playerid][pModel]);
            SendClientMessage(playerid,COLOR_LIGHTRED,"Pilot: {FFFFFF}Please fasten your seatbelts, as we are coming in to land.");
            Flight[playerid] = 1;
            SetTimerEx("Plane", 1000, false, "i", playerid);
            UpdatePlayerInfo(playerid);
        }
	}
    else if(PlayerInfo[playerid][pMember] != 0)
    {
	     SetPlayerSpawn(playerid);
	}
	if(PlayerInfo[playerid][pDied] == 1)
	{
        SetPlayerPos(playerid,PlayerInfo[playerid][pPosX],PlayerInfo[playerid][pPosY],PlayerInfo[playerid][pPosZ]);
        SetPlayerFacingAngle(playerid,134.1570);
        PlayerInfo[playerid][pInt] = 0;
        SetPlayerInterior(playerid,PlayerInfo[playerid][pInt]);
        SendClientMessage(playerid,COLOR_MEDIC,"~ You have just got out from hospital");
        SendClientMessage(playerid,COLOR_MEDIC,"~ You have payed your bill 1000$");
        Otman_TakePlayerMoney(playerid,1000);
        TogglePlayerControllable(playerid, 1);
        SetPlayerHealth(playerid, 90);
        PlayerInfo[playerid][pDied] = 0;
        return 1;
	}
	if(PlayerInfo[playerid][pDied] == 2)
	{
        SetPlayerPos(playerid,PlayerInfo[playerid][pPosX],PlayerInfo[playerid][pPosY],PlayerInfo[playerid][pPosZ]);
        SetPlayerInterior(playerid,PlayerInfo[playerid][pInt]);
        DieTime[playerid] = SetTimerEx("DieingTimer", 1000, true, "i7", playerid);
        TogglePlayerControllable(playerid, 0);
        SetPlayerDrunkLevel(playerid, 500);
        SetPlayerHealth(playerid, 20);
        gPlayerUsingLoopingAnim[playerid] = 2;
        Freezed[playerid] = 1;
        LoopingAnim(playerid, "CRACK", "crckdeth2", 4.0, 1, 0, 0, 0, 0);
        return 1;
	}
	if(PlayerInfo[playerid][pDied] == 3)
	{
        SetPlayerPos(playerid,2530.5117,-4687.9072,52.6292);
        SetPlayerFacingAngle(playerid,167.6372);
        LoopingAnim(playerid,"BEACH", "bather", 4.0, 1, 0, 0, 0, 0);
		DieTime[playerid] = SetTimerEx("HospTimer", 1000, true, "i8", playerid);
        return 1;
	}
    if(PlayerInfo[playerid][pJailed] == 1)
	{
	    SetPlayerInterior(playerid, 6);
		SetPlayerPos(playerid,198.4892,162.0331,1003.0300);
		SendClientMessage(playerid, COLOR_RED, "BACK TO JAIL");
	}
	for(new h = 0; h < sizeof(HouseInfo); h++)
	{
		if(PlayerInfo[playerid][pMember] == 0)
	    {
            if (strmatch(HouseInfo[h][hOwner],Spielername(playerid)))
	        {
	             SetPlayerInterior(playerid,HouseInfo[h][hInt]);
	             SetPlayerVirtualWorld(playerid,HouseInfo[h][hNumber]);
	             SetPlayerPos(playerid,HouseInfo[h][hExitx],HouseInfo[h][hExity],HouseInfo[h][hExitz]);
		         PlayerInfo[playerid][pInt] = HouseInfo[h][hInt];
			}
		}
	}
    for(new h = 0; h < sizeof(HouseInfo); h++)
	{
		if(PlayerInfo[playerid][pRentHouse] == HouseInfo[h][hNumber] && PlayerInfo[playerid][pMember] == 0)
	    {
	        if(HouseInfo[h][hLock] == 0)
	        {
	             SetPlayerInterior(playerid,HouseInfo[h][hInt]);
	             SetPlayerVirtualWorld(playerid,HouseInfo[h][hNumber]);
	             SetPlayerPos(playerid,HouseInfo[h][hExitx],HouseInfo[h][hExity],HouseInfo[h][hExitz]);
		         PlayerInfo[playerid][pInt] = HouseInfo[h][hInt];
			}
			if(HouseInfo[h][hLock] == 1)
	        {
	             SetPlayerInterior(playerid,0);
	             SetPlayerPos(playerid,HouseInfo[h][hEntrancex],HouseInfo[h][hEntrancey],HouseInfo[h][hEntrancez]);
		         PlayerInfo[playerid][pInt] = 0;
		         PlayerInfo[playerid][pRentHouse] = 0;
		         SendClientMessage(playerid, COLOR_RED, "[Owner]: House is closed this is the last time you will spawn here");
			}
			else if(HouseInfo[h][hLabLvl] == 1)
	        {
	             SetPlayerInterior(playerid,0);
	             SetPlayerPos(playerid,HouseInfo[h][hEntrancex],HouseInfo[h][hEntrancey],HouseInfo[h][hEntrancez]);
		         PlayerInfo[playerid][pInt] = 0;
		         PlayerInfo[playerid][pRentHouse] = 0;
		         SendClientMessage(playerid, COLOR_RED, "[Owner]: House is closed this is the last time you will spawn here");
			}
		}
	}
	SetPlayerFightingStyle(playerid, PlayerInfo[playerid][pFightStyle]);
	playerpack(playerid);
	return 0;
}

public OnPlayerDeath(playerid, killerid, reason)
{
    PlayerDead[playerid] = 1;
    if(WeaponsLoaded[playerid] == 1) { WeaponsLoaded[playerid] = 0; }
    Otman_ResetPlayerWeapons(playerid);
    PlayerInfo[playerid][pHandsGun1] = 0; PlayerInfo[playerid][pHandsBullets1] = 0;
    PlayerInfo[playerid][pHandsGun2] = 0; PlayerInfo[playerid][pHandsBullets2] = 0;
    PlayerInfo[playerid][pHandsGun3] = 0; PlayerInfo[playerid][pHandsBullets3] = 0;
    PlayerInfo[playerid][pHandsGun4] = 0; PlayerInfo[playerid][pHandsBullets4] = 0;
    new string[256];
    new name[MAX_PLAYER_NAME];
    new caller = Mobile[playerid];
    OnDuty[playerid] = 0;
    if(speedmeteron[playerid] == 1)
	{
        speedmeteron[playerid] = 0;
        KillTimer(speedmetertimer[playerid]);
        HideSpeedMeter(playerid);
	}
	if(caller != 255)
	{
	    if(caller < 255)
		{
			SendClientMessage(caller,  COLOR_GRAD2, "The line Disconnected...");
			CellTime[caller] = 0;
			CellTime[playerid] = 0;
			Mobile[caller] = 255;
			SetPlayerSpecialAction(caller,SPECIAL_ACTION_STOPUSECELLPHONE);
		}
	    Mobile[playerid] = 255;
	    CellTime[playerid] = 0;
	}
	if(gPlayerUsingLoopingAnim[playerid])
	{
        gPlayerUsingLoopingAnim[playerid] = 0;
    }
	if(PlayerInfo[playerid][pHeadValue] > 0)
	{
	    if(IsPlayerConnected(killerid))
	    {
		    if(PlayerInfo[killerid][pMember] == 6 || PlayerInfo[killerid][pLeader] == 6)
		    {
		        if(GoChase[killerid] == playerid)
		        {
					new killer[MAX_PLAYER_NAME];
					GetPlayerName(killerid, killer, sizeof(killer));
					Otman_GivePlayerMoney(killerid, PlayerInfo[playerid][pHeadValue]);
					format(string,128,"<< Hitman %s has fulfilled the contract on %s and collected $%d >>",killer,name,PlayerInfo[playerid][pHeadValue]);
					SendFamilyMessage(Hitmen, COLOR_YELLOW, string);
					PlayerInfo[playerid][pHeadValue] = 0;
					GotHit[playerid] = 0;
					GetChased[playerid] = 999;
					GoChase[killerid] = 999;
				}
			}
		}
	}
	if(RentedCar[playerid] != 0)
	{
        SetVehicleToRespawn(RentedCar[playerid]);
	    RentedCar[playerid] = 0;
	}
	if(PlayerInfo[playerid][pJob] > 0)
	{
        if(JobDuty[playerid] > 0)
        {
            JobDuty[playerid] = 1;
        }
	}
	if(PlayerInfo[playerid][pMember] == Police)
	{
        if(OnDuty[playerid] > 0)
        {
            OnDuty[playerid] = 0;
        }
	}
	if(PlayerInfo[playerid][pDied] == 0)
	{
		if(reason == 22 || reason == 23 || reason == 24 || reason == 25 || reason == 29 || reason == 30 || reason == 31)
		{
            PlayerInfo[playerid][pPosX] = 2026.4174;
            PlayerInfo[playerid][pPosY] = -1422.1005;
            PlayerInfo[playerid][pPosZ] = 16.9922;
            PlayerInfo[playerid][pDied] = 1;
            return 1;
		}
		else
		{
            new Float:X, Float:Y, Float:Z;
            GetPlayerPos(playerid, X, Y, Z);
            PlayerInfo[playerid][pPosX] = X;
            PlayerInfo[playerid][pPosY] = Y;
            PlayerInfo[playerid][pPosZ] = Z;
            PlayerInfo[playerid][pDied] = 2;
            PlayerInfo[playerid][pDiedTime] = 60;
            return 1;
		}
	}
	return 1;
}

public OnVehicleSpawn(vehicleid)
{
	return 1;
}

public OnVehicleDeath(vehicleid, killerid)
{
	if(GetCreatorID(vehicleid)!=0)
	{
	    new create = GetCreatorID(vehicleid);
	    DestroyVehicle(vehicleid);
	    new CAR = CreateVehicle(VehicleSystem[create][model],VehicleSystem[create][carx],VehicleSystem[create][cary],VehicleSystem[create][carz],VehicleSystem[create][cara],VehicleSystem[create][Farbe1],VehicleSystem[create][Farbe2],600000);
	    Tunen(CAR);
	}
}

