public CheckGas()
{
	for(new i=0;i<GetMaxPlayers();i++)
	{
    	if(IsPlayerConnected(i))
       	{
       	    if(GetPlayerState(i) == PLAYER_STATE_DRIVER)
       	    {
	       		new vehicle = GetPlayerVehicleID(i);
	       		new string[256];
	       		if(GetVehicleModel(GetPlayerVehicleID(i)) == 416)
                {
					return 1;
				}
	        	if(Gas[vehicle] >= 1)
		   		{
		   		    if(Gas[vehicle] <= 10) { PlayerPlaySound(i, 1085, 0.0, 0.0, 0.0); }
		   		    if(gGas[i] == 1) {
		   		    format(string,sizeof(string),"<< Fuel: %d% >>",Gas[vehicle]);
				    SendClientMessage(i,COLOR_LIGHTBLUE,string); }
	              	Gas[vehicle]--;
	              	return 1;
		   		}
	   			else
	           	{
	              	format(string,sizeof(string),"<< Your Vehicle is Out of Fule >>");
				    SendClientMessage(i,COLOR_LIGHTBLUE,string);
				    RemovePlayerFromVehicle(i);
				    return 1;
				}
			}
			return 1;
    	}
	}
	return 1;
}

public SpeedMeter(playerid)
{
    if(IsPlayerInAnyVehicle(playerid))
    {
            new Float: vPos[3],Float: Speed,string[128];
	        new Float:health;
		    GetVehicleHealth(GetPlayerVehicleID(playerid), health);
	        new vehicle = GetPlayerVehicleID(playerid);
	        new fuel = Gas[GetPlayerVehicleID(playerid)];
		    if(Engine[vehicle] != 1)
            {
				return 1;
			}
            if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
            {
                format(string, sizeof(string), "%s",CarName[GetVehicleModel(GetPlayerVehicleID(playerid))-400]), TextDrawSetString(Textdraw3[playerid],string),TextDrawShowForPlayer(playerid, Textdraw3[playerid]);
                format(string, sizeof(string), "%d",fuel);
                TextDrawSetString(Textdraw7[playerid],string);
                TextDrawShowForPlayer(playerid, Textdraw2[playerid]);
                TextDrawShowForPlayer(playerid, Textdraw3[playerid]);
                TextDrawShowForPlayer(playerid, Textdraw5[playerid]);
                TextDrawShowForPlayer(playerid, Textdraw6[playerid]);
                TextDrawShowForPlayer(playerid, Textdraw7[playerid]);
                TextDrawShowForPlayer(playerid, Textdraw8[playerid]);
                if(!IsVehicleDrivingBackwards(GetPlayerVehicleID(playerid)))
		        {
                    GetVehicleVelocity(GetPlayerVehicleID(playerid), vPos[0], vPos[1], vPos[2]);
			        Speed = floatmul(floatsqroot(floatadd(floatpower(vPos[0], 2), floatadd(floatpower(vPos[1], 2), floatpower(vPos[2], 2)))), 200);
			        format(string, sizeof(string), "%0.0f", Speed), TextDrawSetString(Textdraw4[playerid], string), TextDrawShowForPlayer(playerid, Textdraw4[playerid]);
		            if(Speed < 1)
                    {
                        TextDrawHideForPlayer(playerid, Textdraw9[playerid]);
			            TextDrawSetString(Textdraw9[playerid], "Gear  ~w~R ~g~N ~w~D"), TextDrawShowForPlayer(playerid, Textdraw9[playerid]);
                    }
                    if(Speed > 1)
	                {
			            TextDrawHideForPlayer(playerid, Textdraw9[playerid]);
			            TextDrawSetString(Textdraw9[playerid], "Gear  ~w~R ~w~N ~g~D"), TextDrawShowForPlayer(playerid, Textdraw9[playerid]);
		            }
                    return 1;
			    }
            }
            if(IsVehicleDrivingBackwards(GetPlayerVehicleID(playerid)))
		    {
                TextDrawSetString(Textdraw9[playerid], "Gear  ~p~R ~w~N ~w~D"), TextDrawShowForPlayer(playerid, Textdraw9[playerid]);
   			    TextDrawSetString(Textdraw4[playerid], "~r~0"), TextDrawShowForPlayer(playerid, Textdraw4[playerid]);
   			    return 1;
			}
    }
    else if(speedmeteron[playerid] == 1)
    {
        speedmeteron[playerid] = 0;
        KillTimer(speedmetertimer[playerid]);
        HideSpeedMeter(playerid);
	}
    return 1;
}

stock IsVehicleDrivingBackwards(vehicleid) // By Joker
{
	new Float:Float[3];
	if(GetVehicleVelocity(vehicleid, Float[1], Float[2], Float[0]))
	{
		GetVehicleZAngle(vehicleid, Float[0]);
		if(Float[0] < 90)
		{
			if(Float[1] > 0 && Float[2] < 0) return true;
		}
		else if(Float[0] < 180)
		{
			if(Float[1] > 0 && Float[2] > 0) return true;
		}
		else if(Float[0] < 270)
		{
			if(Float[1] < 0 && Float[2] > 0) return true;
		}
		else if(Float[1] < 0 && Float[2] < 0) return true;
	}
	return false;
}

public DetFindTimer(playerid)
{
   if(DetFind[playerid] == 1)
   {
       DisablePlayerCheckpoint(playerid);
       DetFind[playerid] = 0;
   }
   return 1;
}

public IsAPizzaBike(carid)
{
	if(carid >= 27 && carid <= 31)
	{
		return 1;
	}
	return 0;
}

public SetPlayerStuffs()
{
    for(new i = 0; i < GetMaxPlayers(); i++)
	{
	    if(IsPlayerConnected(i))
	    {
            new string[256];
            new level = PlayerInfo[i][pLevel];
			if(level >= 0 && level <= 2) { PlayerInfo[i][pPayCheck] += 1; }
			else if(level >= 3 && level <= 4) { PlayerInfo[i][pPayCheck] += 2; }
			else if(level >= 5 && level <= 6) { PlayerInfo[i][pPayCheck] += 3; }
			else if(level >= 7 && level <= 8) { PlayerInfo[i][pPayCheck] += 4; }
			else if(level >= 9 && level <= 10) { PlayerInfo[i][pPayCheck] += 5; }
			else if(level >= 11 && level <= 12) { PlayerInfo[i][pPayCheck] += 6; }
			else if(level >= 13 && level <= 14) { PlayerInfo[i][pPayCheck] += 7; }
			else if(level >= 15 && level <= 16) { PlayerInfo[i][pPayCheck] += 8; }
			else if(level >= 17 && level <= 18) { PlayerInfo[i][pPayCheck] += 9; }
			else if(level >= 19 && level <= 20) { PlayerInfo[i][pPayCheck] += 10; }
			else if(level >= 21) { PlayerInfo[i][pPayCheck] += 11; }
	        if(PizzaCallTime[i] > 0)
   			{
   			    if(Logged[i] == 1)
   			    {
       			    if(PizzaCallTime[i] == 180) { PizzaCallTime[i] = 0; DisablePlayerCheckpoint(i); PlayerPlaySound(i, 1056, 0.0, 0.0, 0.0); SendClientMessage(i, COLOR_RED, "[Duty]: The Redmarker is gone"); }
       			    else
    			    {
        			    format(string, sizeof(string), "%d", 180 - PizzaCallTime[i]);
     				    GameTextForPlayer(i, string, 1500, 6);
     				    PizzaCallTime[i] += 1;
					}
    			}
   			}
   			if(gPlayerUsingLoopingAnim[i] == 1)
			{
                if(PickProds[i] == 10)
			    {
				    LoopingAnim(i,"CARRY","crry_prtial",4.1,0,1,1,1,1);
			    }
			}
	        if(MechanicCallTime[i] > 0)
	        {
	            if(MechanicCallTime[i] == 30) { MechanicCallTime[i] = 0; DisablePlayerCheckpoint(i); PlayerPlaySound(i, 1056, 0.0, 0.0, 0.0); GameTextForPlayer(i, "~r~RedMarker gone", 2500, 1); }
	            else
		        {
		            format(string, sizeof(string), "%d", 30 - MechanicCallTime[i]);
			        GameTextForPlayer(i, string, 1500, 6);
			        MechanicCallTime[i] += 1;
			    }
			}
            if(PlayerInfo[i][pJailed] > 0)
		    {
				if(PlayerInfo[i][pJailTime] > 0)
				{
		    		PlayerInfo[i][pJailTime]--;
					format(string, sizeof(string), "~r~%d Seconds",PlayerInfo[i][pJailTime]);
					GameTextForPlayer(i, string, 2000, 1);
				}
				if(PlayerInfo[i][pJailTime] <= 0)
				{
				    PlayerInfo[i][pJailTime] = 0;
					if(PlayerInfo[i][pJailed] == 1)
					{
					    PlayerInfo[i][pJailed] = 0;
					    SendClientMessage(i, COLOR_PINKY,"<< You Have Payed Your Debt,You Are Free To Go >>");
					    TogglePlayerControllable(i, 1);
					    SetPlayerInterior(i,0);
					    SetPlayerPos(i,1554.2712,-1675.5537,16.1953);
	                    Freezed[i] = 0;
	                    if(AdminJail[i] == 1) { AdminJail[i] = 0; }
					}
				}
			}
			if(Tazed[i] == 1)
			{
			    if(TazedTime[i] <= 0)
			    {
			        TogglePlayerControllable(i, 1);
			        Tazed[i] = 0;
			        TazedTime[i] = 0;
			        Freezed[i] = 0;
			    }
			    else
			    {
			        TazedTime[i] -= 1;
			    }
			}
			if(PlayerInfo[i][pCarTime] > 0)
			{
			    if(PlayerInfo[i][pCarTime] <= 0)
			    {
			        PlayerInfo[i][pCarTime] = 0;
			    }
			    else
			    {
			        PlayerInfo[i][pCarTime] -= 1;
			    }
			}
			if(CellTime[i] > 0)
			{
				if (CellTime[i] == cchargetime)
				{
					CellTime[i] = 1;
					if(Mobile[Mobile[i]] == i)
					{
                        for(new h = 0; h < sizeof(PCInfo); h++)
	                    {
							if(PlayerInfo[i][pCellphone] == PCInfo[h][pcNum])
							{
						        CallCost[i] += PCInfo[h][pcCallPrice];
							}
						}
					}
				}
				CellTime[i] = CellTime[i] +1;
				if (Mobile[Mobile[i]] == 255 && CellTime[i] == 5)
				{
				    if(IsPlayerConnected(Mobile[i]))
				    {
						new called[MAX_PLAYER_NAME];
						GetPlayerName(Mobile[i], called, sizeof(called));
						format(string, sizeof(string), "%s's phone rings", called);
						ProxDetector(20.0, Mobile[i], string, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
					}
				}
			}
			if(CellTime[i] == 0 && CallCost[i] > 0)
			{
				format(string, sizeof(string), "~w~The call cost~n~~r~$%d",CallCost[i]);
				Otman_TakePlayerMoney(i,CallCost[i]);
				GameTextForPlayer(i, string, 5000, 1);
				CallCost[i] = 0;
			}
		}
	}
}

public SendJobMessage(job, color, string[])
{
    for(new i = 0; i < GetMaxPlayers(); i++)
	{
		if(IsPlayerConnected(i))
		{
		    if(PlayerInfo[i][pJob] == job)
		    {
				SendClientMessage(i, color, string);
			}
		}
	}
	return 1;
}

public PlayerStats(playerid,targetid)
{
    if(IsPlayerConnected(playerid)&&IsPlayerConnected(targetid))
	{
		new cash =  Otman_GetPlayerMoney(targetid);
		new atext[20];
		if(PlayerInfo[targetid][pSex] == 1) { atext = "Male"; }
		else if(PlayerInfo[targetid][pSex] == 2) { atext = "Female"; }
  		new otext[20];
		if(PlayerInfo[targetid][pOrigin] == 1) { otext = "Los Santos"; }
		else if(PlayerInfo[targetid][pOrigin] == 2) { otext = "Las Vanturas"; }
		else if(PlayerInfo[targetid][pOrigin] == 3) { otext = "San Fiero"; }
		new ttext[30];
		if(PlayerInfo[targetid][pMember] == Police || PlayerInfo[targetid][pLeader] == Police) { ttext = "Police Department"; }
		else if(PlayerInfo[targetid][pMember] == FBI || PlayerInfo[targetid][pLeader] == FBI) { ttext = "FBI"; }
		else if(PlayerInfo[targetid][pMember] == Triads || PlayerInfo[targetid][pLeader] == Triads) { ttext = "Triads"; }
		else if(PlayerInfo[targetid][pMember] == Italian || PlayerInfo[targetid][pLeader] == Italian) { ttext = "The Valenti Crime Family"; }
		else if(PlayerInfo[targetid][pMember] == Russian || PlayerInfo[targetid][pLeader] == Russian) { ttext = "The Whitecomb Mob"; }
		else if(PlayerInfo[targetid][pMember] == Hitmen || PlayerInfo[targetid][pLeader] == Hitmen) { ttext = "The Unknown"; }
		else if(PlayerInfo[targetid][pMember] == Taxi || PlayerInfo[targetid][pLeader] == Taxi) { ttext = "Taxi Company"; }
		else if(PlayerInfo[targetid][pMember] == Grove || PlayerInfo[targetid][pLeader] == Grove) { ttext = "Southside Malditos X3"; }
		else if(PlayerInfo[targetid][pMember] == Medic || PlayerInfo[targetid][pLeader] == Medic) { ttext = "EMS"; }
		else if(PlayerInfo[targetid][pMember] == LSS || PlayerInfo[targetid][pLeader] == LSS) { ttext = "Product Courier"; }
		else{ ttext = "None"; }
	    new rtext[64];
	    if(PlayerInfo[targetid][pMember] == Police || PlayerInfo[targetid][pLeader] == Police)//PD Ranks
		{
		    if(PlayerInfo[targetid][pRank] == 1) { rtext = "Police Officer I"; }
			else if(PlayerInfo[targetid][pRank] == 2) { rtext = "Police Officer II"; }
			else if(PlayerInfo[targetid][pRank] == 3) { rtext = "Police Officer III"; }
			else if(PlayerInfo[targetid][pRank] == 4) { rtext = "Senior Police Officer"; }
			else if(PlayerInfo[targetid][pRank] == 5) { rtext = "Sergeant"; }
			else if(PlayerInfo[targetid][pRank] == 6) { rtext = "Staff Sergeant"; }
			else if(PlayerInfo[targetid][pRank] == 7) { rtext = "Lieutenant I"; }
