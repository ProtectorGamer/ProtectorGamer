forward SaveTool(count);
public SaveTool(count)
{
	new saver[40];
	if(!dini_Exists("LG/Vehicles/PlayerVehicles/Cars.ini"))
	{
	    return 0;
	}
	if(count != 0)
	{
	    if(VehicleSystem[count][model]!=0)
	    {
			Savingcars = 1;
	        format(saver,sizeof(saver),"veh_model_%d",count);
            dini_IntSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][model]);
            format(saver,sizeof(saver),"veh_x_%d",count);
            dini_FloatSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][carx]);
            format(saver,sizeof(saver),"veh_y_%d",count);
            dini_FloatSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][cary]);
            format(saver,sizeof(saver),"veh_z_%d",count);
            dini_FloatSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][carz]);
            format(saver,sizeof(saver),"veh_a_%d",count);
            dini_FloatSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][cara]);
            format(saver,sizeof(saver),"veh_Farbe1_%d",count);
            dini_IntSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][Farbe1]);
            format(saver,sizeof(saver),"veh_Farbe2_%d",count);
            dini_IntSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][Farbe2]);
            format(saver,sizeof(saver),"veh_owner_%d",count);
            dini_Set("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][owner]);
            format(saver,sizeof(saver),"veh_description_%d",count);
            dini_Set("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][Description]);
            format(saver,sizeof(saver),"veh_preis_%d",count);
            dini_IntSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][preis]);
            format(saver,sizeof(saver),"veh_license_%d",count);
            dini_IntSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][License]);
            format(saver,sizeof(saver),"veh_registration_%d",count);
            dini_IntSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][Registration]);
            format(saver,sizeof(saver),"veh_halarm_%d",count);
            dini_IntSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][HAlarm]);
            format(saver,sizeof(saver),"veh_alarm_%d",count);
            dini_IntSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][Alarm]);
            format(saver,sizeof(saver),"veh_hgps_%d",count);
            dini_IntSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][HGps]);
            format(saver,sizeof(saver),"veh_gps_%d",count);
            dini_IntSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][Gps]);
            format(saver,sizeof(saver),"veh_hplate_%d",count);
            dini_IntSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][HPlate]);
            format(saver,sizeof(saver),"veh_plate_%d",count);
            dini_Set("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][Plate]);
            format(saver,sizeof(saver),"veh_insr_%d",count);
            dini_IntSet("LG/Vehicles/PlayerVehicles/Cars.ini",saver,VehicleSystem[count][Insr]);
            format(saver,sizeof(saver),"veh_key_%d",count);
