forward LoadTool(playerid,i);
public LoadTool(playerid,i)
{
    if(!dini_Exists("LG/Vehicles/PlayerVehicles/Cars.ini"))
	{
	    return 0;
	}
	new loader[40];
	if(i == PlayerInfo[playerid][pVeh1] || i == PlayerInfo[playerid][pVeh2] || i == PlayerInfo[playerid][pVeh3] || i == PlayerInfo[playerid][pVeh4] || i == PlayerInfo[playerid][pVeh5])
	{
        Loadingcars = 1;
        format(loader,sizeof(loader),"veh_model_%d",i);
	    VehicleSystem[i][model] = dini_Int("LG/Vehicles/PlayerVehicles/Cars.ini",loader);
	    format(loader,sizeof(loader),"veh_x_%d",i);
	    VehicleSystem[i][carx] = dini_Float("LG/Vehicles/PlayerVehicles/Cars.ini",loader);
