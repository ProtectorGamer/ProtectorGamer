	if(strcmp(cmd, "/pay", true) == 0)
	{
	    if(Logged[playerid] == 1)
	    {
			tmp = strtok(cmdtext, idx);
			if(!strlen(tmp))
			{
				SendClientMessage(playerid, COLOR_GRAD1, "Function: {FFFFFF}/pay [ID or Name/Part of name] [amount]");
				return 1;
			}
			//giveplayerid = strval(tmp);
	        giveplayerid = ReturnUser(tmp);
			tmp = strtok(cmdtext, idx);
			if(!strlen(tmp))
			{
				SendClientMessage(playerid, COLOR_GRAD1, "Function: {FFFFFF}/pay [ID or Name/Part of name] [amount]");
				return 1;
			}
			moneys = strval(tmp);
			if(moneys < 1 || moneys > 10000000)
			{
			    SendClientMessage(playerid, COLOR_GRAD1, "Dont go below $1 or above $10 Million at once.");
			    return 1;
			}
			if(moneys > 1500 && PlayerInfo[playerid][pLevel] < 2)
			{
				SendClientMessage(playerid, COLOR_GRAD1, "You must be level 3 to pay over 1500");
				return 1;
			}
			if (IsPlayerConnected(giveplayerid))
			{
			    if(giveplayerid != INVALID_PLAYER_ID)
			    {
					if (ProxDetectorS(5.0, playerid, giveplayerid))
					{
						GetPlayerName(giveplayerid, giveplayer, sizeof(giveplayer));
						GetPlayerName(playerid, sendername, sizeof(sendername));
						playermoney = Otman_GetPlayerMoney(playerid);
						if (moneys > 0 && playermoney >= moneys)
						{
							Otman_TakePlayerMoney(playerid, (0 , moneys));
							Otman_GivePlayerMoney(giveplayerid, moneys);
							format(string, sizeof(string), "You have sent %s [%d] a total of $%d.", giveplayer,giveplayerid, moneys);
							PlayerPlaySound(playerid, 1052, 0.0, 0.0, 0.0);
							SendClientMessage(playerid, COLOR_YELLOW, string);
							format(string, sizeof(string), "You have received $%d from %s [%d]", moneys, sendername, playerid);
							SendClientMessage(giveplayerid, COLOR_Milito, string);
							format(string, sizeof(string), "%s has paid $%d to %s.", sendername, moneys, giveplayer);
							if(moneys >= 1000000)
							{
								ABroadCast(COLOR_YELLOW,string,1);
							}
							PlayerPlaySound(giveplayerid, 1052, 0.0, 0.0, 0.0);
							format(string, sizeof(string), "%s reaches in to their pocket, withdrawing a wad of cash, extending it out to %s and handing over the cash.", sendername ,giveplayer);
							ProxDetector(10.0, playerid, string, COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE,COLOR_PURPLE);
						}
						else
						{
							SendClientMessage(playerid, COLOR_GRAD1, "Invalid transaction amount");
						}
					}
					else
					{
						SendClientMessage(playerid, COLOR_GRAD1, "Your too far away");
					}
				}//invalid id
			}
			else
			{
				format(string, sizeof(string), "%d is not an active player", giveplayerid);
				SendClientMessage(playerid, COLOR_GRAD1, string);
			}
		}
		return 1;
	}
