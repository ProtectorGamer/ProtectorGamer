public Otman_GivePlayerMoney(playerid, amount)
{
    GivePlayerMoney(playerid, amount);
	Otman[playerid][acCash] = GetPlayerMoney(playerid);
}

public Otman_TakePlayerMoney(playerid, amount)
{
    GivePlayerMoney(playerid, -amount);
    Otman[playerid][acCash] = GetPlayerMoney(playerid);
}

stock Otman_ResetPlayerMoney(playerid)
{
	Otman[playerid][acCash] -= Otman[playerid][acCash];
	GivePlayerMoney(playerid, Otman[playerid][acCash]-Otman[playerid][acCash]);
}

stock Otman_ResetPlayerWeapons(playerid)
{
	ResetPlayerWeapons(playerid);
}

public Otman_GetPlayerMoney(playerid)
{
	return Otman[playerid][acCash];
}
