                for(new h = 0;h<MAX_BUY_V;h++)
	            {
                    new Float:vX,Float:vY,Float:vZ;
                    GetVehiclePos(h,vX,vY,vZ);
		            if(PlayerToPoint(3.0, playerid, vX,vY,vZ))
		            {
	                    if(GetCreatorID(h)!=0)
	                    {
	                        if (strmatch(VehicleSystem[GetCreatorID(h)][owner],Spielername(playerid)))
	                        {
								if(VehicleSystem[GetCreatorID(h)][Faction] != 0)
								{
                                    VehicleSystem[GetCreatorID(h)][Faction] = 0;
                                    format(string, sizeof(string), "Details: Vehicle[%d] has been unseted from faction[%d]",GetCreatorID(h),PlayerInfo[playerid][pMember]);
                                    SendClientMessage(playerid,COLOR_GREY,string);
                                    PlayerPlaySound(playerid,1056,vX,vY,vZ);
                                    SaveTool(GetCreatorID(h));
                                    return 1;
								}
						    }
						}
					}
				}
				return 1;
			}
			if(strcmp(x_nr,"lock",true) == 0)
	        {
                for(new h = 0;h<MAX_BUY_V;h++)
	            {
                    new Float:vX,Float:vY,Float:vZ;
                    GetVehiclePos(h,vX,vY,vZ);
		            if(PlayerToPoint(3.0, playerid, vX,vY,vZ))
