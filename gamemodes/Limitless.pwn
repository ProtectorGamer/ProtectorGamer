}

public StopCameraEffect(playerid)
{
    SetPlayerDrunkLevel(playerid, 0);
	return 1;
}

public TempBanCheck(playerid)
{
	new ip[15];
	new str[128];
	new load[4][32];
	new ban_day, ban_month, ban_year, ban_ip[15];
	GetPlayerIp(playerid, ip, sizeof ip);
	new year, month, day;
	getdate(year, month, day);
	new File:file = fopen("LG/Accounts/TempBanned/TempBans.ban",io_read);
	if (file)
	{
	    while (fread(file, str, sizeof str))
	    {
	        split(str, load, '|');
	        ban_day = strval(load[0]);
	        ban_month = strval(load[1]);
	        ban_year = strval(load[2]);
	        strmid(ban_ip, load[3], 0, strlen(load[3])-1, 15);
	    	if (!(year >= ban_year && month >= ban_month && day >= ban_day) && !strcmp(ban_ip, ip, true))
	    	{
	    	    format(str, sizeof str, "You are temporarily banned from this server until: %d/%d/%d", ban_day, ban_month, ban_year);
	    	    SendClientMessage(playerid, COLOR_RED, str);
	    	    return Kick(playerid);
	    	}
		}
	}
	return 1;
}

stock IsMonth31(month)
{
 	switch (month)
	{
	    case 1: return 1;
	    case 3: return 1;
	    case 5: return 1;
	    case 7: return 1;
	    case 8: return 1;
	    case 10: return 1;
	    case 12: return 1;
	    default: return 0;
	}
	return 0;
}

stock IsMonth29(year)
{
 	new y = 2000;
 	for(new i = 4; i < 3000; i += 4) if ((y+i) == year) return 1;
 	return 0;
}

stock bigstr(const string[], &idx)
{
    new length = strlen(string);
	while ((idx < length) && (string[idx] <= ' '))
	{
		idx++;
	}
	new offset = idx;
	new result[128];
	while ((idx < length) && ((idx - offset) < (sizeof(result) - 1)))
	{
		result[idx - offset] = string[idx];
		idx++;
	}
	result[idx - offset] = EOS;
	return result;
}
////////////////////////////////////---Anticheat----//////////////////////////////////////////

public WeaponDetection(playerid)
{
    if(TOGGLE_WEAPON_DETECTION == ON)
	{
        if(Logged[playerid] == 0)
		{
			return 1;
		}
		if(PlayerDead[playerid] == 1)
		{
			return 1;
		}
        if(GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_USEJETPACK)
	    {
	        HackingDetected(playerid, "JetpackHack");
	        return 1;
		}
    }
    return 1;
}

public MoneyDetection(playerid)
{
    new cash = GetPlayerMoney(playerid);
    new hack[100];
    if(Logged[playerid] == 0)
	{
		return 1;
	}
    if (cash > Otman[playerid][acCash])
    {
        if ((cash - Otman[playerid][acCash]) >= MONEY_HACK)
        {
            format(hack, sizeof(hack),"MoneyHack +[$%d]",(cash - Otman[playerid][acCash]));
            HackingDetected(playerid,hack);
            return 1;
		}
    }
    if((cash-Otman[playerid][acCash]) > 0)
    {
        new removemoney = GetPlayerMoney(playerid)-Otman[playerid][acCash];
        Otman_TakePlayerMoney(playerid,removemoney);
        return 1;
    }
    return 1;
}

public HealthDetection(playerid)
{
	if(Logged[playerid] == 1)
	{
	    KillTimer(hhtime[playerid]);
	    new Float:hp;
	    GetPlayerHealth(playerid, hp);
	    if (hp >= 100)
	    {
	        if (GetPlayerPing(playerid) < 700)
	        {
	            SetPlayerHealth(playerid, 99);
	            hhtime[playerid] = SetTimerEx("HealthDetection",1000,0,"d",playerid);
	            return;
	        }
	    }
	    hhtime[playerid] = SetTimerEx("HealthDetection",1000,0,"d",playerid);
	}
}

public HealthHackSuspection(suspectid)
{
	if(Logged[suspectid] == 1)
	{
	    new Float:hp;
	    GetPlayerHealth(suspectid, hp);
	    if (hp >= 100)
	    {
	        if (GetPlayerPing(suspectid) < 700) HackingDetected(suspectid, "HealthHack");
	    }
	}
}

public HackingDetected(playerid, reason[])
{
	new string[128];
	new name[MAX_PLAYER_NAME];
	GetPlayerName(playerid, name, sizeof(name));
	if (HACKER == BAN)
	{
	    format(string, sizeof(string), "Anti-Cheat has banned %s | Reason: %s", name, reason);
	    SendClientMessageToAll(ADMIN_RED, string);
	    new file[100];
	    format(file, sizeof(file),"LG/Accounts/BannedPlayers/%s.ban",name);
        dini_Create(file);
        dini_Set(file,"Banned-By","Server Auto Ban [AntiCheat]");
        dini_Set(file,"Reason",reason);
        KillTimer(MoneyDetectionTimer[playerid]);
        KillTimer(WeaponDetectionTimer[playerid]);
        Kick(playerid);
        return 1;
	}
	else if (HACKER == KICK)
	{
	    format(string, sizeof(string), "[SERVER]: has kicked %s | Reason: %s", name, reason);
	    SendClientMessageToAll(ADMIN_RED, string);
	    KillTimer(MoneyDetectionTimer[playerid]);
        KillTimer(WeaponDetectionTimer[playerid]);
	    Kick(playerid);
	    return 1;
	}
	return 1;
}

stock GetPlayerWeaponSlotID(weapon)
{
	new slot;
	if(weapon == 0 || weapon == 1){ slot = 0; return slot; }
    if(weapon >= 2 && weapon <= 9){ slot = 1; return slot; }
	if(weapon >= 10 && weapon <= 15){ slot = 10; return slot; }
	if(weapon >= 16 && weapon <= 18){ slot = 8; return slot; }
	if(weapon >= 22 && weapon <= 24){ slot = 2; return slot; }
	if(weapon >= 25 && weapon <= 27){ slot = 3; return slot; }
	if(weapon >= 28 && weapon <= 29 || weapon == 32){ slot = 4; return slot; }
	if(weapon >= 30 && weapon <= 31){ slot = 5; return slot; }
	if(weapon >= 33 && weapon <= 34){ slot = 6; return slot; }
	if(weapon >= 35 && weapon <= 38){ slot = 7; return slot; }
	if(weapon == 39){ slot = 8; return slot; }
	if(weapon == 40){ slot = 12; return slot; }
	if(weapon >= 41 && weapon <= 43){ slot = 9; return slot; }
	if(weapon >= 44 && weapon <= 46){ slot = 11; return slot; }
	return 12;
}

stock GetWeapSlotID(weaponid)
{
	switch (weaponid)
	{
	    case 0,1: return 0;
	    case 2..9: return 1;
	    case 10..15: return 10;
	    case 16..18,39: return 8;
	    case 22..24: return 2;
	    case 25..27: return 3;
	    case 28,29,32: return 4;
	    case 33,34: return 6;
	    case 35..38: return 7;
	    case 41..43: return 9;
	    case 44..46: return 11;
	    default: return 12;
	}
	return 0;
}

