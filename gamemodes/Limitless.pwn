public PayDay()
{
	new string[128];
    for(new i = 0; i < GetMaxPlayers(); i++)
	{
		if(IsPlayerConnected(i))
		{
		    if(PlayerInfo[i][pLevel] > 0)
		    {
				new playername2[MAX_PLAYER_NAME];
				GetPlayerName(i, playername2, sizeof(playername2));
				if(PlayerInfo[i][pPayDay] >= 5)
				{
					new checks = PlayerInfo[i][pPayCheck];
					PlayerPlayMusic(i);
					new interest = (checks/1000)*(2);
					PlayerInfo[i][pExp]++;
					PlayerInfo[i][pAccount] += interest+checks;
					SendClientMessage(i, COLOR_GREEN, "------[ PayDay ]------");
					format(string, sizeof(string), "Paycheck: $%d", checks);
					SendClientMessage(i, COLOR_WHITE2, string);
					format(string, sizeof(string), "Interest Gained $%d", interest);
					SendClientMessage(i, COLOR_WHITE2, string);
					SendClientMessage(i, COLOR_WHITE2, "|-----------------------------|");
					format(string, sizeof(string), "New Balance: $%d", PlayerInfo[i][pAccount]);
					SendClientMessage(i, COLOR_WHITE2, string);
					SendClientMessage(i, COLOR_LIGHTRED, "Details: You must go to the bank so you can pickup your check!");
					format(string, sizeof(string), "~p~Pay~w~Day");
					GameTextForPlayer(i, string, 5000, 1);
					PlayerInfo[i][pPayDay] = 0;
					PlayerInfo[i][pPayCheck] = 0;
					new nxtlevel = PlayerInfo[i][pLevel]+1;
	                new expamount = nxtlevel*levelexp;
					if (PlayerInfo[i][pExp] == expamount)
					{
						format(string, sizeof(string), "Details: Congratulations You Have Upgraded your level, you are now level %d", nxtlevel);
						SendClientMessage(i, 0x078301FF, string);
						PlayerPlaySound(i, 1052, 0.0, 0.0, 0.0);
						PlayerInfo[i][pLevel]++;
						PlayerInfo[i][pExp] = 0;
						if(PlayerInfo[i][pDonateRank] > 0)
						{
						    PlayerInfo[i][pExp] -= expamount;
						    new total = PlayerInfo[i][pExp];
						    if(total > 0)
						    {
						        PlayerInfo[i][pExp] = total;
						    }
						    else
						    {
						        PlayerInfo[i][pExp] = 0;
						    }
						}
					}
				}
				else
				{
				    SendClientMessage(i, COLOR_LIGHTRED, "You haven't played long enough to obtain a PayDay!");
				}
			}
		}
	}
}

public PayCheck()
{
    for(new i = 0; i < GetMaxPlayers(); i++)
	{
		if(IsPlayerConnected(i))
		{
		    if(PlayerInfo[i][pPayDay] < 6) { PlayerInfo[i][pPayDay] += 1; } //+ 5 min to PayDay anti-abuse
		}
	}
}

public unlocktimercar(playerid, vehicleid)
{
	for(new i=0;i<GetMaxPlayers();i++)
	{
		SetVehicleParamsForPlayer(vehicleid,i, 0, 0);
	}
    lockedcar[playerid][vehicleid] = 0;
    lockedveh[vehicleid] = 0;
}

public OnVehicleStreamIn(vehicleid, forplayerid)
{
    if(GetCreatorID(vehicleid) != 0)
    {
        if(VehicleSystem[GetCreatorID(vehicleid)][Lock] == 1)
        {
            SetVehicleParamsForPlayer(vehicleid, forplayerid, 0, 1); // Lock the car whene streamin
		}
    }
    if(lockedveh[vehicleid] == 1)
    {
        SetVehicleParamsForPlayer(vehicleid, forplayerid, 0, 1);
	}
	if(lockedcar[forplayerid][vehicleid] == 1)
	{
        SetVehicleParamsForPlayer(vehicleid, forplayerid, 0, 0);
	}
    return 1;
}

public OnPlayerInteriorChange(playerid, newinteriorid, oldinteriorid)
{
	// IF ANYONE IS SPECTATING THIS PLAYER, WE'LL ALSO HAVE
	// TO CHANGE THEIR INTERIOR ID TO MATCH
	new x = 0;
	while(x!=MAX_PLAYERS) {
	    if( IsPlayerConnected(x) &&	GetPlayerState(x) == PLAYER_STATE_SPECTATING &&
			gSpectateID[x] == playerid && gSpectateType[x] == ADMIN_SPEC_TYPE_PLAYER )
   		{
   		    SetPlayerInterior(x,newinteriorid);
		}
		x++;
	}
}

stock encode_lights(light1, light2, light3, light4)
{
	return light1 | (light2 << 1) | (light3 << 2) | (light4 << 3);
}

