	if(strcmp(cmd, "/ajail", true) == 0)
	{
	    if(IsPlayerConnected(playerid) && PlayerInfo[playerid][pAdmin] >= 1)
	    {
			tmp = strtok(cmdtext, idx);
			if(!strlen(tmp))
			{
				SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/ajail [ID or Name/Part of name] [time(min)] [reason]");
				return 1;
			}
			new playa;
			new money;
			playa = ReturnUser(tmp);
			tmp = strtok(cmdtext, idx);
			money = strval(tmp);
			new length = strlen(cmdtext);
			while ((idx < length) && (cmdtext[idx] <= ' '))
			{
				idx++;
			}
			new offset = idx;
			new result[255];
			while ((idx < length) && ((idx - offset) < (sizeof(result) - 1)))
			{
				result[idx - offset] = cmdtext[idx];
				idx++;
			}
			result[idx - offset] = EOS;
			if(!strlen(result))
			{
				SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/ajail [ID or Name/Part of name] [time(min)] [reason]");
				return 1;
			}
			if (PlayerInfo[playerid][pAdmin] >= 1)
			{

			    if(IsPlayerConnected(playa))
			    {
			        if(playa != INVALID_PLAYER_ID)
			        {
				        GetPlayerName(playa, giveplayer, sizeof(giveplayer));
						GetPlayerName(playerid, sendername, sizeof(sendername));
						format(string, sizeof(string), "[ADMCMD] %s has Admin Jailed %s for %d minutes, the reason is: %s", sendername, giveplayer, money, (result) );
						SendClientMessageToAll(COLOR_RIGHTHAND_DONS, string);
						Otman_ResetPlayerWeapons(playa);
						if(WeaponsLoaded[playa] == 1) { WeaponsLoaded[playa] = 0; }
						PlayerInfo[playa][pHandsGun1] = 0; PlayerInfo[playa][pHandsBullets1] = 0;
	                    PlayerInfo[playa][pHandsGun2] = 0; PlayerInfo[playa][pHandsBullets2] = 0;
                        PlayerInfo[playa][pHandsGun3] = 0; PlayerInfo[playa][pHandsBullets3] = 0;
	                    PlayerInfo[playa][pHandsGun4] = 0; PlayerInfo[playa][pHandsBullets4] = 0;
						PlayerInfo[playa][pJailed] = 1;
						PlayerInfo[playa][pJailTime] = money*60;
						SetPlayerInterior(playa, 6);
						SetPlayerPos(playa, 264.6288,77.5742,1001.0391);
						AdminJail[playa] = 1;
					}
				}
			}
			else
			{
				SendClientMessage(playerid, COLOR_GRAD1, "You do not have the sufficient rights to utilize the following function.");
			}
		}
		return 1;
	}
