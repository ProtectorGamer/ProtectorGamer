                                    SendClientMessage(playerid, COLOR_PINKY, "Details: Your vehicle dont have an installed alarm system");
				                    return 1;
						        }
							    if(VehicleSystem[GetCreatorID(h)][Alarm] == 0)
							    {
				                    VehicleSystem[GetCreatorID(h)][Alarm] = 1;
				                    SendClientMessage(playerid, COLOR_PINKY, "Details: Vehicle Alarm turned on");
				                    return 1;
								}
								if(VehicleSystem[GetCreatorID(h)][Alarm] == 1)
							    {
				                    VehicleSystem[GetCreatorID(h)][Alarm] = 0;
				                    beeps[h] = 0;
				                    SendClientMessage(playerid, COLOR_PINKY, "Details: Vehicle Alarm turned off");
				                    return 1;
								}
							}
						}
					}
				}
			}
			if(strcmp(x_nr,"locate",true) == 0)
	        {
                new car;
                tmp = strtok(cmdtext, idx);
	            car = strval(tmp);
			    if(!strval(tmp))
			    {
                    SendClientMessage(playerid, COLOR_RED, "Correct: locate [Carid]");
		            return 1;
		        }
		        for(new h = 0;h<MAX_BUY_V;h++)
	            {
                    new Float:vX,Float:vY,Float:vZ;
                    GetVehiclePos(h,vX,vY,vZ);
                    if (strmatch(VehicleSystem[GetCreatorID(h)][owner],Spielername(playerid)))
	                {
	                    if(VehicleSystem[GetCreatorID(h)][HGps] == 1)
		                {
							if(GetCreatorID(h) == car)
	                        {
                                if(CarLocate[playerid] == 0)
							    {
		                            SetPlayerCheckpoint(playerid,vX,vY,vZ, 5.0);
		                            SendClientMessage(playerid,COLOR_PINKY,"[GPS]: Your Vehicle Position Has Been Located In The Map At The Red Point");
		                            CarLocate[playerid] = 1;
							    }
							    else
							    {
							        SendClientMessage(playerid,COLOR_RED,"[GPS]: Your Vehicle Tracking has been canceled");
	                                DisablePlayerCheckpoint(playerid);
	                                CarLocate[playerid] = 0;
							    }
							}
						}
					}
				}
			}
			if(strcmp(x_nr,"pack",true) == 0)
	        {
			    for(new h = 0;h<MAX_BUY_V;h++)
	            {
                    new Float:vX,Float:vY,Float:vZ;
                    GetVehiclePos(h,vX,vY,vZ);
                    if(GetCreatorID(h) != 0)
	                {
	                    if(VehicleSystem[GetCreatorID(h)][Trunk] == 0)
	                    {
	                        if(PlayerToPoint(3.0, playerid, vX,vY,vZ))
		                    {
		                        SendClientMessage(playerid, COLOR_PINKY, "Vehicle Packages");
		                        format(string, sizeof(string), "1:%s[%d] - 2:%s[%d] - 3:%s[%d] - 4:%s[%d]",VehicleSystem[GetCreatorID(h)][Guns1Name], VehicleSystem[GetCreatorID(h)][Bullets1],VehicleSystem[GetCreatorID(h)][Guns2Name], VehicleSystem[GetCreatorID(h)][Bullets2],VehicleSystem[GetCreatorID(h)][Guns3Name], VehicleSystem[GetCreatorID(h)][Bullets3],VehicleSystem[GetCreatorID(h)][Guns4Name], VehicleSystem[GetCreatorID(h)][Bullets4]);
		                        SendClientMessage(playerid, COLOR_WHITE2, string);
		                        format(string, sizeof(string), "5:%s[%d] - 6:%s[%d] - 7:%s[%d] - 8:%s[%d]",VehicleSystem[GetCreatorID(h)][Guns5Name], VehicleSystem[GetCreatorID(h)][Bullets5],VehicleSystem[GetCreatorID(h)][Guns6Name], VehicleSystem[GetCreatorID(h)][Bullets6],VehicleSystem[GetCreatorID(h)][Guns7Name], VehicleSystem[GetCreatorID(h)][Bullets7],VehicleSystem[GetCreatorID(h)][Guns8Name], VehicleSystem[GetCreatorID(h)][Bullets8]);
		                        SendClientMessage(playerid, COLOR_WHITE2, string);
		                        format(string, sizeof(string), "9:%s[%d] - 10:%s[%d] - 11:%s[%d] - 12:%s[%d]",VehicleSystem[GetCreatorID(h)][Guns9Name], VehicleSystem[GetCreatorID(h)][Bullets9],VehicleSystem[GetCreatorID(h)][Guns10Name], VehicleSystem[GetCreatorID(h)][Bullets10],VehicleSystem[GetCreatorID(h)][Guns11Name], VehicleSystem[GetCreatorID(h)][Bullets11],VehicleSystem[GetCreatorID(h)][Guns12Name], VehicleSystem[GetCreatorID(h)][Bullets12]);
		                        SendClientMessage(playerid, COLOR_WHITE2, string);
		                        return 1;
						    }
					    }
					    SendClientMessage(playerid, COLOR_GREY, "Vehicle trunk is closed");
		                return 1;
				    }
			    }
		    }
			if(strcmp(x_nr,"sell",true) == 0)
	        {
                tmp = strtok(cmdtext, idx);
	            if(!strlen(tmp))
	            {
                    SendClientMessage(playerid, COLOR_GREY, "Function: {FFFFFF}/sell [PlayerID] [Price]");
		            return 1;
                }
                new playa;
                playa = ReturnUser(tmp);
                new price;
                tmp = strtok(cmdtext, idx);
                price = strval(tmp);
                if(!strval(tmp))
                {
                    SendClientMessage(playerid, COLOR_GREY, "Function: {FFFFFF}/sell [PlayerID] [Price]");
                    return 1;
	            }
		        for(new h = 0;h<MAX_BUY_V;h++)
	            {
                    new Float:vX,Float:vY,Float:vZ;
                    GetVehiclePos(h,vX,vY,vZ);
		            if(PlayerToPoint(3.0, playerid, vX,vY,vZ))
		            {
	                    if(GetCreatorID(h)!=0)
	                    {
	                        if (strmatch(VehicleSystem[GetCreatorID(h)][owner],Spielername(playerid)))
	                        {
                                if(VehicleSystem[GetCreatorID(h)][Faction] != 0)
                                {
                                    SendClientMessage(playerid, COLOR_GREY, "Details: You cannot sell a faction vehicle. Use '/v unsetfaction' to remove it from the faction.");
									return 1;
								}
                                GetPlayerName(playerid, sendername, sizeof(sendername));
                                GetPlayerName(playa, giveplayer, sizeof(giveplayer));
                                format(string, sizeof(string), "[Offer] %s has offered you their vehicle for $%d. Type {FFFFFF}'/accept Offer' {FFA6FF}to accept the vehicle!",sendername,price);
                         		SendClientMessage(playa,COLOR_PINKY,string);
                         		format(string, sizeof(string), "[Offer] You have offered to sell your to %s, for $%d.",giveplayer,price);
                                SendClientMessage(playerid,COLOR_PINKY,string);
                                CarOffer[playa] = playerid;
                                CarPrice[playa] = price;
							}
						}
					}
				}
			}
	    }
	}
    return 1;
}

public OnPlayerEnterVehicle(playerid, vehicleid, ispassenger)
{
	return 1;
}

public OnPlayerExitVehicle(playerid, vehicleid)
{
   	new sendername[MAX_PLAYER_NAME];
	new giveplayer[MAX_PLAYER_NAME];
	new string[256];
	if(CrashTimerStarted[playerid] == 1)
	{
	    KillTimer(playerspeedtimer[playerid]);
	    CrashTimerStarted[playerid] = 0;
	}
    if(TaxiCab[playerid] == 1)
    {
        Otman_GivePlayerMoney(TaxiDriverID[playerid],TaxiCabTimer[playerid]);
        Otman_TakePlayerMoney(playerid,TaxiCabTimer[playerid]);
        GetPlayerName(TaxiDriverID[playerid], giveplayer, sizeof(giveplayer));
		GetPlayerName(playerid, sendername, sizeof(sendername));
		format(string, sizeof(string), "You have received $%d from %s.",TaxiCabTimer[playerid],sendername);
		SendClientMessage(TaxiDriverID[playerid], COLOR_Milito, string);
		format(string, sizeof(string), "You have paid $%d to %s.",TaxiCabTimer[playerid],giveplayer);
		SendClientMessage(playerid, COLOR_Milito, string);
		KillTimer(TaxiCounterTimer[playerid]);
		TaxiCab[playerid] = 0;
		TaxiCabTimer[playerid] = 0;
		TaxiDriverID[playerid] = 999;
	}
	if(speedmeteron[playerid] == 1)
	{
        speedmeteron[playerid] = 0;
        KillTimer(speedmetertimer[playerid]);
        HideSpeedMeter(playerid);
	}
	return 1;
}

public OnPlayerStateChange(playerid, newstate, oldstate)
{
    new newcar = GetPlayerVehicleID(playerid);
    new string[256];
    if (newstate == PLAYER_STATE_DRIVER)
	{
	    if (VehicleLightsOn[GetPlayerVehicleID(playerid)] == false)
	    {
			GetVehicleDamageStatus(GetPlayerVehicleID(playerid), panels, doors, lightz, tires);
	        UpdateVehicleDamageStatus(GetPlayerVehicleID(playerid), panels, doors, encode_lights(1, 1, 1, 1), tires);
   			VehicleLightsOn[GetPlayerVehicleID(playerid)] = false;
	    }
	    if (VehicleLightsOn[GetPlayerVehicleID(playerid)] == true)
	    {
			GetVehicleDamageStatus(GetPlayerVehicleID(playerid), panels, doors, lightz, tires);
	        UpdateVehicleDamageStatus(GetPlayerVehicleID(playerid), panels, doors, encode_lights(0, 0, 0, 0), tires);
         	VehicleLightsOn[GetPlayerVehicleID(playerid)] = true;
		}
	}
    if(newcar >= 40 && newcar <= 43)
	{
		if (RentedCar[playerid] != newcar && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		{
		    format(string, sizeof(string), "~w~Price:~g~$%d~n~~w~To rent type ~g~/rentcar~w~~n~to get out type ~r~/exit",CrentInfo[0][rcRentCost]);
			TogglePlayerControllable(playerid, 0);
			PriveCar[playerid] = 1;
			GameTextForPlayer(playerid, string, 5000, 3);
			return 1;
		}
	}
	if(newcar >= 44 && newcar <= 47)
	{
	    if (RentedCar[playerid] != newcar && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		{
		    format(string, sizeof(string), "~w~Price:~g~$%d~n~~w~To rent type ~g~/rentcar~w~~n~to get out type ~r~/exit",CrentInfo[1][rcRentCost]);
		    TogglePlayerControllable(playerid, 0);
		    PriveCar[playerid] = 1;
		    GameTextForPlayer(playerid, string, 5000, 3);
		    return 1;
		}
	}
    if(GetPlayerVehicleID(playerid) >= 33 && GetPlayerVehicleID(playerid) <= 35)
    {
	    if(DriverTest[playerid] == 100)
	    {
	        if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
            {
                TogglePlayerControllable(playerid, 0);
	            SendClientMessage(playerid,COLOR_WHITE2,"||- Welcome to the automobile exam, please type /start -||");
	            return 1;
			}
		}
		else
		{
		    RemovePlayerFromVehicle(playerid);
		    TogglePlayerControllable(playerid, 1);
		    return 1;
		}
	}
    if(GetPlayerVehicleID(playerid) == 48 || GetPlayerVehicleID(playerid) == 49)
    {
        if(DriverTest[playerid] == 200)
        {
            if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
            {
                TogglePlayerControllable(playerid, 0);
	            SendClientMessage(playerid,COLOR_WHITE2,"||- Welcome to the boat driving exam, please type /start -||");
	            return 1;
			}
		}
		else
		{
		    RemovePlayerFromVehicle(playerid);
		    TogglePlayerControllable(playerid, 1);
		    return 1;
		}
    }
	if(IsAPizzaBike(newcar))
	{
		if(PlayerInfo[playerid][pJob] != 17 && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
   		{
     		RemovePlayerFromVehicle(playerid);
     		TogglePlayerControllable(playerid, 1);
     		SendClientMessage(playerid,COLOR_GREY,"You are not a Pizza Boy!");
     		return 1;
  		}
    }
    if(IsATaxiCar(newcar))
    {
        if(PlayerInfo[playerid][pMember] != 7)
   		{
            if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
            {
     		    RemovePlayerFromVehicle(playerid);
     		    TogglePlayerControllable(playerid, 1);
     		    SendClientMessage(playerid,COLOR_GREY,"You are not allowed");
     		    return 1;
			}
  		}
    }
    if(GetVehicleModel(GetPlayerVehicleID(playerid)) == 438)
    {
        if(PlayerInfo[playerid][pMember] != 7)
   		{
            if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
            {
     		    RemovePlayerFromVehicle(playerid);
     		    TogglePlayerControllable(playerid, 1);
     		    SendClientMessage(playerid,COLOR_GREY,"You are not allowed");
     		    return 1;
			}
  		}
    }
    if(IsACopCar(newcar))
	{
	    if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
        {
            Copshotgun[playerid] = 1;
	        if(PlayerInfo[playerid][pMember] != Police)
   		    {
  		        RemovePlayerFromVehicle(playerid);
                TogglePlayerControllable(playerid, 1);
                SendClientMessage(playerid,COLOR_GREY,"You are not allowed to drive a police car");
     		    return 1;
			}
		}
	}
	if(GetPlayerVehicleID(playerid) >= 80 && GetPlayerVehicleID(playerid) <= 81)
    {
        if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
        {
            if(PlayerInfo[playerid][pMember] != Police)
   		    {
  		        RemovePlayerFromVehicle(playerid);
                TogglePlayerControllable(playerid, 1);
                SendClientMessage(playerid,COLOR_GREY,"You are not allowed to drive this maverick");
     		    return 1;
			}
		}
	}
    if(IsAFBICar(newcar))
	{
		if(PlayerInfo[playerid][pMember] != FBI || PlayerInfo[playerid][pMember] != Police)
   		{
            if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
            {
     		    RemovePlayerFromVehicle(playerid);
     		    TogglePlayerControllable(playerid, 1);
     		    return 1;
			}
  		}
    }
    if(GetPlayerVehicleID(playerid) == 82)
    {
        if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
        {
            if(PlayerInfo[playerid][pMember] != FBI)
   		    {
  		        RemovePlayerFromVehicle(playerid);
                TogglePlayerControllable(playerid, 1);
                SendClientMessage(playerid,COLOR_GREY,"You are not allowed to drive this maverick");
     		    return 1;
			}
		}
	}
    if(GetVehicleModel(GetPlayerVehicleID(playerid)) == 416)
    {
        if(PlayerInfo[playerid][pMember] != Medic && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
        {
            SendClientMessage(playerid,COLOR_GREY,"You are not allowed to drive an ambulance !");
            RemovePlayerFromVehicle(playerid);
            TogglePlayerControllable(playerid, 1);
            return 1;
        }
	}
   	if(GetVehicleModel(GetPlayerVehicleID(playerid)) == 525)
    {
        if(PlayerInfo[playerid][pJob] != 7 && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
        {
            SendClientMessage(playerid,COLOR_GREY,"You are not a car mechanic !");
            RemovePlayerFromVehicle(playerid);
            TogglePlayerControllable(playerid, 1);
            return 1;
        }
	}
	if(GetVehicleModel(GetPlayerVehicleID(playerid)) == 514)
    {
        if(PlayerInfo[playerid][pMember] != 7 && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
        {
            RemovePlayerFromVehicle(playerid);
            TogglePlayerControllable(playerid, 1);
            return 1;
        }
	}
	if(IsPlayerInAnyVehicle(playerid))
    {
		if(Engine[newcar] != 1 && GetVehicleModel(newcar) != 481 && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		{
            TogglePlayerControllable(playerid, 0);
	        SendClientMessage(playerid,COLOR_LIGHTRED,"The vehicle engine is switched off. Use {FFFFFF}/engine {E26399}to start the engine!");
		}
		if(Engine[newcar] == 1 && GetVehicleModel(newcar) != 481 && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		{
            if(speedmeteron[playerid] == 0)
            {
                speedmetertimer[playerid] = SetTimerEx("SpeedMeter", 150, true, "i", playerid);
                speedmeteron[playerid] = 1;
			}
		}
		if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		{
			if(CrashTimerStarted[playerid] == 0)
			{
                playerspeedtimer[playerid] = SetTimerEx("VehicleSpeed", 500, 1, "i", playerid);
                CrashTimerStarted[playerid] = 1;
			}
		}
	}
	return 1;
}

public OnPlayerEnterCheckpoint(playerid)
{
    for(new i = 0; i < GetMaxPlayers(); i++)
	{
        if(PizzaCallTime[i] > 0 && PizzaCallTime[i] < 180)
	    {
	        PizzaCallTime[i] = 0; DisablePlayerCheckpoint(i); PlayerPlaySound(i, 1056, 0.0, 0.0, 0.0); SendClientMessage(i, COLOR_RED, "[Duty]: The Redmarker is gone");
        }
	}
    for(new i = 0; i < GetMaxPlayers(); i++)
	{
	    if(CarLocate[i] == 1)
	    {
	        DisablePlayerCheckpoint(playerid);
	        CarLocate[playerid] = 0;
	    }
	}
    for(new i = 0; i < GetMaxPlayers(); i++)
	{
	    if(TaxiTime[i] == 1)
	    {
	        DisablePlayerCheckpoint(playerid);
	        TaxiTime[playerid] = 0;
	    }
	}
	if(JobPoint[playerid]==1)
	{
	    if(IsPlayerInAnyVehicle(playerid))
	    {
			SendClientMessage(playerid, COLOR_LIGHTBLUE, "Hint: Please type /sellcar to drop the car");
			PlayerPlaySound(playerid, 1056, 0.0, 0.0, 0.0);
		}
		else
		{
		    GameTextForPlayer(playerid, "~r~Not in a car", 5000, 3);
		}
