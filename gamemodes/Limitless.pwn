	if(strcmp(cmd, "/tempban", true) == 0)
	{
		if (PlayerInfo[playerid][pAdmin] != 0)
		{
			tmp = strtok(cmdtext,idx);
			if(!strlen(tmp))
			{
				SendClientMessage(playerid, COLOR_BROWN, "Function: {FFFFFF}/tempban [playerid] [day] [reason]");
				SendClientMessage(playerid, COLOR_BROWN, "Function: {FFFFFF}/Temporarily bans a player. You must enter the month, day and hour numbers. You set them, not add.");
				return 1;
			}
			giveplayerid = ReturnUser(tmp);
			if(IsPlayerConnected(giveplayerid))
			{
			    tmp = strtok(cmdtext, idx);
			    if (!strlen(tmp)) return SendClientMessage(playerid, COLOR_GREY, "Function: {FFFFFF}/tempban [playerid] [day] [reason]");
				new days = strval(tmp);
				new reason[128];
				reason = bigstr(cmdtext, idx);
				if (!strlen(reason)) return SendClientMessage(playerid, COLOR_GREY, "Function: {FFFFFF}/tempban [playerid] [day] [REASON]");
				new ip[15];
				GetPlayerIp(giveplayerid,ip,15);
				GetPlayerName(playerid, sendername, sizeof sendername);
				GetPlayerName(giveplayerid, giveplayer, sizeof(giveplayer));
				new File:tempban = fopen("LG/Accounts/TempBanned/TempBans.ban", io_append);
				if (tempban)
				{
				    new year,month,day;
				    getdate(year, month, day);
				    day += days;
				    if (IsMonth31(month))
				    {
				        if (day > 31)
				        {
				            month += 1;
				            if (month > 12)
				            {
				                year += 1;
				                while(day > 31) day -= 31;
				            }
				            else while(day > 31) day -= 31;
				        }
				    }
				    else if (!IsMonth31(month))
				    {
				        if (day > 30)
				        {
				            month += 1;
				            if (month > 12)
				            {
				                year += 1;
				                while(day > 30) day -= 30;
				            }
				            else while(day > 30) day -= 30;
				        }
				    }
				    else if (!IsMonth31(month) && IsMonth29(year) && month == 2)
				    {
				        if (day > 29)
				        {
				            month += 1;
				            if (month > 12)
				            {
				                year += 1;
				                while(day > 29) day -= 29;
				            }
				            else while(day > 29) day -= 29;
				        }
				    }
				    else if (!IsMonth31(month) && !IsMonth29(year) && month == 2)
				    {
				        if (day > 28)
				        {
				            month += 1;
				            if (month > 12)
				            {
				                year += 1;
				                while(day > 28) day -= 28;
				            }
				            else while(day > 28) day -= 28;
				        }
				    }
				    format(string, sizeof string, "%d|%d|%d|%s\n", day, month, year, ip);
				    fwrite(tempban, string);
				    fclose(tempban);
				}
				format(string,128,"[TempBan] %s temporarily banned %s for %d day's Reason: %s",sendername,giveplayer,days,reason);
				SendClientMessageToAll(COLOR_RED,string);
				Kick(giveplayerid);
			}
			else
			{
				format(string, sizeof(string), "The given player is not ingame!", giveplayerid);
				SendClientMessage(playerid, COLOR_WHITE2, string);
			}
		}
		else return SendClientMessage(playerid, COLOR_WHITE2, "You are not an admin.");
		return true;
	}
