	if(strcmp(cmd, "/c", true) == 0)
	{
	    if(IsPlayerConnected(playerid))
	    {
	        if(Logged[playerid] == 0)
	        {
	            SendClientMessage(playerid, COLOR_GREY, "You are not logged in");
	            return 1;
	        }
	        if(PlayerInfo[playerid][pJob] != 7)
		    {
		        SendClientMessage(playerid, COLOR_RED, "You are not a Car Mechanic !");
		        return 1;
		    }
	        new x_nr[64];
	        x_nr = strtok(cmdtext, idx);
	        if(!strlen(x_nr))
	        {
	            SendClientMessage(playerid, COLOR_GREY, "Function: {FFFFFF}/(/c)[Action]");
	            SendClientMessage(playerid, COLOR_BROWN, "Value: color - savecolor - repair - refill");
	            SendClientMessage(playerid, COLOR_BROWN, "Value: plate - setalarm - setgps");
	            SendClientMessage(playerid, COLOR_BROWN, "Note: {FFFFFF}to change color you use 'color' after your done use 'savecolor' to save it");
	            return 1;
	        }
	        if(strcmp(x_nr,"repair",true) == 0)
	        {
                tmp = strtok(cmdtext, idx);
			    if(!strlen(tmp))
			    {
				    SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/repair [ID or Name/Part of name] [price]");
				    return 1;
			    }
			    new playa;
			    new money;
			    playa = ReturnUser(tmp);
			    tmp = strtok(cmdtext, idx);
			    money = strval(tmp);
			    if(money < 1 || money > 9999) { SendClientMessage(playerid, COLOR_GREY, "Price not lower then 1, or above 9999!"); return 1; }
			    if(IsPlayerConnected(playa))
			    {
			        if(playa != INVALID_PLAYER_ID)
			        {
			            if(ProxDetectorS(5.0, playerid, playa))
					    {
                            if(GetPlayerState(playa) == PLAYER_STATE_DRIVER)
                            {
                                if(playa == playerid) { SendClientMessage(playerid, COLOR_RED, "You are not allowed to do that !"); return 1; }
			    	            GetPlayerName(playa, giveplayer, sizeof(giveplayer));
                                GetPlayerName(playerid, sendername, sizeof(sendername));
					            format(string, sizeof(string), "You are offering %s to repair his vehile for $%d",giveplayer,money);
						        SendClientMessage(playerid, COLOR_BROWN, string);
						        format(string, sizeof(string), "Mechanic %s wants to repair your vehicle for $%d, (type /accept repair) to accept.",sendername,money);
						        SendClientMessage(playa, COLOR_BROWN, string);
						        RepairCar[playa] = GetPlayerVehicleID(playa);
						        RepairOffer[playa] = playerid;
						        RepairPrice[playa] = money;
						        return 1;
							}
						}
					}
				}
			}
			if(strcmp(x_nr,"color",true) == 0)
	        {
                for(new h = 0;h<MAX_BUY_V;h++)
                {
                    new Float:vX,Float:vY,Float:vZ;
                    GetVehiclePos(h,vX,vY,vZ);
		            if(PlayerToPoint(3.0, playerid, vX,vY,vZ))
		            {
		                if(GetCreatorID(h)==0)
	                    {
							return 1;
						}
				        if(VehicleSystem[GetCreatorID(h)][Opened] == 1)
			            {
                            tmp = strtok(cmdtext, idx);
			                if(!strlen(tmp))
			                {
				                SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/color [color1] [color2]");
				                return 1;
			                }
			                new color1;
			                color1 = strval(tmp);
		                    if(color1 < 0 || color1 > 126)
							{
							    SendClientMessage(playerid, COLOR_GREY, "Color Number can't be below 0 or above 126 !");
								return 1;
							}
			                tmp = strtok(cmdtext, idx);
			                if(!strlen(tmp))
			                {
				                SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/color [color1] [color2]");
				                return 1;
			                }
			                new color2;
			                color2 = strval(tmp);
			                if(color2 < 0 || color2 > 126)
							{
							    SendClientMessage(playerid, COLOR_GREY, "Color Number can't be below 0 or above 126 !");
							    return 1;
							}
							Mcolor1[playerid] = color1;
                            Mcolor2[playerid] = color2;
                            ChangeVehicleColor(h,color1,color2);
						}
					}
				}
				return 1;
			}
			if(strcmp(x_nr,"savecolor",true) == 0)
	        {
                for(new h = 0;h<MAX_BUY_V;h++)
                {
                    new Float:vX,Float:vY,Float:vZ;
                    GetVehiclePos(h,vX,vY,vZ);
		            if(PlayerToPoint(3.0, playerid, vX,vY,vZ))
		            {
                        if(GetCreatorID(h)==0)
	                    {
							return 1;
						}
				        if(VehicleSystem[GetCreatorID(h)][Opened] == 1)
			            {
							VehicleSystem[GetCreatorID(h)][Farbe1] = Mcolor1[playerid];
							VehicleSystem[GetCreatorID(h)][Farbe2] = Mcolor2[playerid];
							PlayerInfo[playerid][pJobExp] += 10;
			                SaveTool(GetCreatorID(h));
                            SendClientMessage(playerid, COLOR_PINKY, "Details: You have changed the color of the car +10 exp");
				            return 1;
						}
					}
				}
			}
			if(strcmp(x_nr,"refill",true) == 0)
	        {
                tmp = strtok(cmdtext, idx);
			    if(!strlen(tmp))
			    {
				    SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/refill [ID or Name/Part of name] [price]");
				    return 1;
			    }
			    new playa;
			    new money;
			    playa = ReturnUser(tmp);
			    tmp = strtok(cmdtext, idx);
			    money = strval(tmp);
			    if(money < 1 || money > 9999) { SendClientMessage(playerid, COLOR_GREY, "Price not lower then 1, or above 9999!"); return 1; }
			    if(IsPlayerConnected(playa))
			    {
			        if(playa != INVALID_PLAYER_ID)
			        {
			            if(ProxDetectorS(8.0, playerid, playa))
					    {
                            if(ProxDetectorS(5.0, playerid, playa))
					        {
                                if(GetPlayerState(playa) == PLAYER_STATE_DRIVER)
                                {
                                    if(playa == playerid) { SendClientMessage(playerid, COLOR_RED, "You are not allowed to do that !"); return 1; }
				    	            GetPlayerName(playa, giveplayer, sizeof(giveplayer));
						            GetPlayerName(playerid, sendername, sizeof(sendername));
					                format(string, sizeof(string), "You are offering %s to refuel his vehicle for $%d",giveplayer,money);
						            SendClientMessage(playerid, COLOR_BROWN, string);
						            format(string, sizeof(string), "Mechanic %s wants to refuel your vehicle for $%d, (type /accept refuel) to accept.",sendername,money);
						            SendClientMessage(playa, COLOR_BROWN, string);
						            RepairCar[playa] = GetPlayerVehicleID(playa);
						            RepairOffer[playa] = playerid;
						            RepairPrice[playa] = money;
						            return 1;
								}
							}
						}
					}
				}
			}
			if(strcmp(x_nr,"setalarm",true) == 0)
	        {
                for(new h = 0;h<MAX_BUY_V;h++)
                {
                    new Float:vX,Float:vY,Float:vZ;
                    GetVehiclePos(h,vX,vY,vZ);
		            if(PlayerToPoint(3.0, playerid, vX,vY,vZ))
		            {
	                    if(GetCreatorID(h)!=0)
	                    {
                            if(VehicleSystem[GetCreatorID(h)][Opened] == 1)
			                {
							    if(VehicleSystem[GetCreatorID(h)][HAlarm] == 0)
							    {
                                    VehicleSystem[GetCreatorID(h)][HAlarm] = 1;
			                        SaveTool(GetCreatorID(h));
                                    SendClientMessage(playerid, COLOR_PINKY, "Details: You have installed an alarm system in the vehicle");
				                    return 1;
