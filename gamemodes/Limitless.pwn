        else if(PlayerInfo[targetid][pJob] == 15) { jtext = "Paper Boy"; }
        else if(PlayerInfo[targetid][pJob] == 16) { jtext = "Truck Driver"; }
        else if(PlayerInfo[targetid][pJob] == 17) { jtext = "Pizza boy"; }
        else { jtext = "None"; }
		new drank[20];
		if(PlayerInfo[targetid][pDonateRank] == 1) { drank = "Tier 1"; }
		else if(PlayerInfo[targetid][pDonateRank] >= 2) { drank = "Tier 2"; }
		else { drank = "Un-Subscribed"; }
		new age = PlayerInfo[targetid][pAge];
		new level = PlayerInfo[targetid][pLevel];
		new name[MAX_PLAYER_NAME];
		GetPlayerName(targetid, name, sizeof(name));
		new coordsstring[256];
		new nxtlevel = PlayerInfo[targetid][pLevel]+1;
		new expamount = nxtlevel*levelexp;
		new exp = PlayerInfo[targetid][pExp];
		if(PlayerInfo[targetid][pPnumber] == 0)
		{
		    format(coordsstring, sizeof(coordsstring),"Statistics of %s",name);
		    SendClientMessage(playerid, COLOR_PINKY,coordsstring);
		    format(coordsstring, sizeof(coordsstring), "Level: %d || Gender: %s || Age: %d || Citizenship: %s", level,atext,age,otext);
		    SendClientMessage(playerid, COLOR_WHITE2,coordsstring);
		    format(coordsstring, sizeof(coordsstring), "Employement: %s || Balance: $%d || Pay-Cheque: $%d || Phone Number: None",jtext,cash,PlayerInfo[targetid][pAccount]);
		    SendClientMessage(playerid, COLOR_WHITE2,coordsstring);
		    format(coordsstring, sizeof(coordsstring), "Affiliation: %s || Rank: %s || Faction Payment: $%d || Subscription: %s || EXP: %d/%d",ttext,rtext,PlayerInfo[targetid][pFacCheck],drank,exp,expamount);
		    SendClientMessage(playerid, COLOR_WHITE2,coordsstring);
		    return 1;
		}
		else if(PlayerInfo[targetid][pPnumber] > 0)
		{
		    format(coordsstring, sizeof(coordsstring),"Statistics of %s",name);
		    SendClientMessage(playerid, COLOR_PINKY,coordsstring);
		    format(coordsstring, sizeof(coordsstring), "Level: %d || Gender: %s || Age: %d || Citizenship: %s", level,atext,age,otext);
		    SendClientMessage(playerid, COLOR_WHITE2,coordsstring);
		    format(coordsstring, sizeof(coordsstring), "Employement: %s || Balance: $%d || Pay-Cheque: $%d || Phone Number: %d",jtext,cash,PlayerInfo[targetid][pAccount],PlayerInfo[targetid][pPnumber]);
		    SendClientMessage(playerid, COLOR_WHITE2,coordsstring);
		    format(coordsstring, sizeof(coordsstring), "Affiliation: %s || Rank: %s || Faction Payment: $%d || Subscription: %s || EXP: %d/%d",ttext,rtext,PlayerInfo[targetid][pFacCheck],drank,exp,expamount);
		    SendClientMessage(playerid, COLOR_WHITE2,coordsstring);
		    return 1;
		}
	}
	return 1;
}
//-----------------------------------
LoopingAnim(playerid,animlib[],animname[], Float:Speed, looping, lockx, locky, lockz, lp)
{
    gPlayerUsingLoopingAnim[playerid] = 1;
    ApplyAnimation(playerid, animlib, animname, Speed, looping, lockx, locky, lockz, lp);
}
//---------------------------------------
OnePlayAnim(playerid,animlib[],animname[], Float:Speed, looping, lockx, locky, lockz, lp)
{
	ApplyAnimation(playerid, animlib, animname, Speed, looping, lockx, locky, lockz, lp);
}
//----------------------------------------
StopLoopingAnim(playerid)
{
	gPlayerUsingLoopingAnim[playerid] = 0;
    ApplyAnimation(playerid, "CARRY", "crry_prtial", 4.0, 0, 0, 0, 0, 0);
}

public PreloadAnimLib(playerid, animlib[])
{
	ApplyAnimation(playerid,animlib,"null",0.0,0,0,0,0,0);
}
//---------------------------------------------------------------------
IsKeyJustDown(key, newkeys, oldkeys)
{
	if((newkeys & key) && !(oldkeys & key)) return 1;
	return 0;
}

