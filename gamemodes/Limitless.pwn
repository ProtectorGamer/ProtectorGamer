			                    else if(PlayerInfo[playerid][pRank] == 5) { rtext = "Dispatcher"; }
			                    else if(PlayerInfo[playerid][pRank] == 6) { rtext = "Shift Supervisor"; }
			                    else if(PlayerInfo[playerid][pRank] == 7) { rtext = "Manager"; }
		                        else if(PlayerInfo[playerid][pRank] == 8) { rtext = "Taxi Company Owner"; }
		                    }
		                    else if(PlayerInfo[playerid][pMember] == Grove || PlayerInfo[playerid][pLeader] == Grove)//424JF Ranks
		                    {
		                        if(PlayerInfo[playerid][pRank] == 1) { rtext = "B.G"; }
			                    else if(PlayerInfo[playerid][pRank] == 2) { rtext = "Thug"; }
			                    else if(PlayerInfo[playerid][pRank] == 3) { rtext = "Soldier"; }
			                    else if(PlayerInfo[playerid][pRank] == 4) { rtext = "Veteran"; }
			                    else if(PlayerInfo[playerid][pRank] == 5) { rtext = "Street Veteran"; }
		                        else if(PlayerInfo[playerid][pRank] == 6) { rtext = "Jefferson O.G."; }
		                    }
		                    else if(PlayerInfo[playerid][pMember] == Medic || PlayerInfo[playerid][pLeader] == Medic)//Medic Ranks
		                    {
		                        if(PlayerInfo[playerid][pRank] == 1) { rtext = "Ambulance Driver"; }
			                    else if(PlayerInfo[playerid][pRank] == 2) { rtext = "Paramedic"; }
			                    else if(PlayerInfo[playerid][pRank] == 3) { rtext = "Paramedic Healer"; }
			                    else if(PlayerInfo[playerid][pRank] == 4) { rtext = "Paramedic Doctor"; }
		                    }
					        format(string, 256, "(( %s %s: %s ))",rtext,sendername,result);
					        SendClientMessage(i, COLOR_LIGHTBLUE, string);
						}
					}
				}
			}
		}
		return 1;
	}
	if(strcmp(cmd, "/getfreq", true) == 0)
	{
	    if(Logged[playerid] == 1)
	    {
		    if(PlayerInfo[playerid][pRadio] == 1)
		    {
                if(PlayerInfo[playerid][pMember] > 2)
				{
                    for(new h = 0; h < sizeof(HQInfo); h++)
	                {
					    if(HQInfo[h][hqID] == PlayerInfo[playerid][pMember])
						{
                            if(HQInfo[h][hqFreq] == 0)
                            {
								SendClientMessage(playerid,COLOR_GREY,"There is no frequence seted for your faction");
								return 1;
							}
                            format(string, 256, "Your faction frequence is (%d) use /setfreq [%d] to logon",HQInfo[h][hqFreq],HQInfo[h][hqFreq]);
                            SendClientMessage(playerid, COLOR_GREEN, string);
                            return 1;
						}
					}
				}
                if(PlayerInfo[playerid][pMember] == 1)
				{
                    if(pdfreq == 0)
                    {
				        SendClientMessage(playerid,COLOR_GREY,"There is no frequence seted for your faction");
						return 1;
				    }
                    format(string, 256, "Your faction frequence is (%d) use /setfreq [%d] to logon",pdfreq);
                    SendClientMessage(playerid, COLOR_GREEN, string);
                    return 1;
				}
				if(PlayerInfo[playerid][pMember] == 2)
				{
                    if(fbifreq == 0)
                    {
				        SendClientMessage(playerid,COLOR_GREY,"There is no frequence seted for your faction");
						return 1;
				    }
                    format(string, 256, "Your faction frequence is (%d) use /setfreq [%d] to logon",fbifreq);
                    SendClientMessage(playerid, COLOR_GREEN, string);
                    return 1;
				}
			}
			else {
			SendClientMessage(playerid,COLOR_GREY,"You dont have a radio, you get one from 7 elevel shops"); return 1;}
		}
		return 1;
	}
	if(strcmp(cmd, "/setfreq", true) == 0)
	{
	    if(Logged[playerid] == 1)
	    {
		    if(PlayerInfo[playerid][pRadio] == 1)
		    {
		        tmp = strtok(cmdtext, idx);
		        if(!strlen(tmp))
		        {
		            SendClientMessage(playerid, COLOR_GREY, "You didn't put any frequence");
		            return 1;
				}
				new id = strval(tmp);
				if(id >= 999999 || id <= 100000)
		        {
			        SendClientMessage(playerid, COLOR_GREY, "Only Frequences 100000 to 999999 are susported");
			        return 1;
				}
				else
		        {
			        PlayerInfo[playerid][pLine] = id;
			        UpdatePlayerInfo(playerid);
			        format(string, 256, "[Radio] Your radio Frequence has been seted to (%d)", id);
			        SendClientMessage(playerid, 0xFFFFFFFF, string);
					if(PlayerInfo[playerid][pLeader] > 2)
					{
                        for(new h = 0; h < sizeof(HQInfo); h++)
	                    {
							if(HQInfo[h][hqID] == PlayerInfo[playerid][pLeader])
							{
                                HQInfo[h][hqFreq] = id;
                                format(string, 256, "[NEWS] New radio frequence has been seted (%d)", id);
                                SendFamilyMessage(PlayerInfo[playerid][pLeader],COLOR_PROMOTE,string);
                                SaveHQ();
							}
					    }
					}
                    if(PlayerInfo[playerid][pLeader] == 1)
					{
                        format(string, 256, "[NEWS] New radio frequence has been seted (%d)", id);
                        SendFamilyMessage(PlayerInfo[playerid][pLeader],COLOR_PROMOTE,string);
                        pdfreq = id;
					}
					if(PlayerInfo[playerid][pLeader] == 2)
					{
                        format(string, 256, "[NEWS] New radio frequence has been seted (%d)", id);
                        SendFamilyMessage(PlayerInfo[playerid][pLeader],COLOR_PROMOTE,string);
                        fbifreq = id;
					}
				}
			}
			else {
			SendClientMessage(playerid,COLOR_GREY,"You dont have a radio, you get one from 7 elevel shops"); return 1;}
		}
		return 1;
	}
	if(strcmp(cmd, "/report", true) == 0)
	{
	    if(IsPlayerConnected(playerid))
	    {
	        GetPlayerName(playerid, sendername, sizeof(sendername));
			new length = strlen(cmdtext);
			while ((idx < length) && (cmdtext[idx] <= ' '))
			{
				idx++;
			}
			new offset = idx;
			new result[255];
			while ((idx < length) && ((idx - offset) < (sizeof(result) - 1)))
			{
				result[idx - offset] = cmdtext[idx];
				idx++;
			}
			result[idx - offset] = EOS;
			if(!strlen(result))
			{
				SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/report [text]");
				return 1;
			}
			format(string, sizeof(string), "[Report]: from %s(%d): %s", sendername,playerid, (result));
			ABroadCast(COLOR_LIGHTRED,string,1);
			SendClientMessage(playerid, COLOR_YELLOW,string);
	    }
	    return 1;
	}
	if(strcmp(cmd, "/a", true) == 0)
	{
	    if(IsPlayerConnected(playerid))
