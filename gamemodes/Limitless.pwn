   			else if(PlayerInfo[playerid][pRank] == 7)
   			{
			SetPlayerColor(playerid,COLOR_CIVILIAN);
			SetPlayerSkin(playerid,PlayerInfo[playerid][pModel]);
			}
			else if(PlayerInfo[playerid][pRank] == 8)
   			{
			SetPlayerColor(playerid,COLOR_CIVILIAN);
			SetPlayerSkin(playerid,294);
			}
			return 1;
  	    }
	    if (PlayerInfo[playerid][pMember] == Taxi || PlayerInfo[playerid][pLeader] == Taxi) //Taxi Cab Company spawn
	    {
	        SetPlayerColor(playerid,COLOR_YELLOW);
			SetPlayerInterior(playerid,0);
			PlayerInfo[playerid][pInt] = 0;
		}
		if (PlayerInfo[playerid][pMember] == Grove || PlayerInfo[playerid][pLeader] == Grove) //424JF spawn
	    {
	        if(PlayerInfo[playerid][pRank] == 1)
   			{
			SetPlayerColor(playerid,COLOR_WHITE);
			SetPlayerSkin(playerid,106);
			}
			else if(PlayerInfo[playerid][pRank] == 2)
   			{
			SetPlayerColor(playerid,COLOR_WHITE);
			SetPlayerSkin(playerid,107);
			}
			else if(PlayerInfo[playerid][pRank] == 3)
   			{
			SetPlayerColor(playerid,COLOR_WHITE);
			SetPlayerSkin(playerid,105);
			}
			else if(PlayerInfo[playerid][pRank] == 4)
   			{
			SetPlayerColor(playerid,COLOR_WHITE);
			SetPlayerSkin(playerid,271);
			}
			else if(PlayerInfo[playerid][pRank] == 5)
   			{
			SetPlayerColor(playerid,COLOR_WHITE);
			SetPlayerSkin(playerid,270);
			}
			else if(PlayerInfo[playerid][pRank] == 6)
   			{
			SetPlayerColor(playerid,COLOR_WHITE);
			SetPlayerSkin(playerid,107);
			}
   			else if(PlayerInfo[playerid][pRank] == 7)
   			{
			SetPlayerColor(playerid,COLOR_WHITE);
			SetPlayerSkin(playerid,269);
			}
			else if(PlayerInfo[playerid][pRank] == 8)
   			{
			SetPlayerColor(playerid,COLOR_WHITE);
			SetPlayerSkin(playerid,242);
			}
			return 1;
  	    }
		if (PlayerInfo[playerid][pMember] == Medic || PlayerInfo[playerid][pLeader] == Medic) //Medic spawn
	    {
            if(PlayerInfo[playerid][pRank] == 1)
   			{
	            SetPlayerColor(playerid,COLOR_MEDIC);
			    SetPlayerSkin(playerid,274);
                return 1;
			}
			else if(PlayerInfo[playerid][pRank] == 2)
   			{
	            SetPlayerColor(playerid,COLOR_MEDIC);
			    SetPlayerSkin(playerid,275);
                return 1;
			}
			else if(PlayerInfo[playerid][pRank] == 3)
   			{
	            SetPlayerColor(playerid,COLOR_MEDIC);
			    SetPlayerSkin(playerid,276);
                return 1;
			}
			else if(PlayerInfo[playerid][pRank] == 4)
   			{
	            SetPlayerColor(playerid,COLOR_MEDIC);
			    SetPlayerSkin(playerid,70);
                return 1;
			}
			return 1;
	    }
	    if (PlayerInfo[playerid][pMember] == LSS || PlayerInfo[playerid][pLeader] == LSS)//LSS Spawn
		{
			if(PlayerInfo[playerid][pRank] == 1 && PlayerInfo[playerid][pSex] == 1)
   			{
			SetPlayerColor(playerid,COLOR_LSS);
			SetPlayerSkin(playerid,27);
			}
   			else if(PlayerInfo[playerid][pRank] == 2 && PlayerInfo[playerid][pSex] == 1)
   			{
			SetPlayerColor(playerid,COLOR_LSS);
			SetPlayerSkin(playerid,27);
			}
			else if(PlayerInfo[playerid][pRank] == 3 && PlayerInfo[playerid][pSex] == 1)
   			{
			SetPlayerColor(playerid,COLOR_LSS);
			SetPlayerSkin(playerid,187);
			}
			else if(PlayerInfo[playerid][pRank] == 4)
   			{
			SetPlayerColor(playerid,COLOR_LSS);
			SetPlayerSkin(playerid,153);
			}
			else if(PlayerInfo[playerid][pRank] == 5)
   			{
			SetPlayerColor(playerid,COLOR_LSS);
			SetPlayerSkin(playerid,126);
			}
			else if(PlayerInfo[playerid][pRank] == 6)
   			{
			SetPlayerColor(playerid,COLOR_LSS);
			SetPlayerSkin(playerid,125);
			}
			else if(PlayerInfo[playerid][pRank] == 7)
   			{
			SetPlayerColor(playerid,COLOR_LSS);
			SetPlayerSkin(playerid,147);
			}
			else if(PlayerInfo[playerid][pRank] == 8)
   			{
			SetPlayerColor(playerid,COLOR_LSS);
			SetPlayerSkin(playerid,147);
			}
			return 1;
		}
	}
	return 1;
}

public PlayerToPoint(Float:radi, playerid, Float:x, Float:y, Float:z)
{
    if(IsPlayerConnected(playerid))
	{
		new Float:oldposx, Float:oldposy, Float:oldposz;
		new Float:tempposx, Float:tempposy, Float:tempposz;
		GetPlayerPos(playerid, oldposx, oldposy, oldposz);
		tempposx = (oldposx -x);
		tempposy = (oldposy -y);
		tempposz = (oldposz -z);
		//printf("DEBUG: X:%f Y:%f Z:%f",posx,posy,posz);
		if (((tempposx < radi) && (tempposx > -radi)) && ((tempposy < radi) && (tempposy > -radi)) && ((tempposz < radi) && (tempposz > -radi)))
		{
			return 1;
		}
	}
	return 0;
}

