			else if(PlayerInfo[playerid][pAdmin] == 4) { admtext = "Level 4 Admin"; }
			else if(PlayerInfo[playerid][pAdmin] == 3) { admtext = "Level 3 Admin"; }
			else if(PlayerInfo[playerid][pAdmin] == 2)	{ admtext = "Level 2 Admin"; }
			else if(PlayerInfo[playerid][pAdmin] == 1) { admtext = "Level 1 Admin"; }
			else { admtext = "Level 1 Admin"; }
			new name[MAX_PLAYER_NAME];
			GetPlayerName(playerid, name, sizeof(name));
			{
				if(Aduty[playerid] == 0)
				{
					format(string, sizeof(string), "[A] %s %s is now on duty as an administrator!",admtext,name);
					Aduty[playerid] = 1;
					SendClientMessageToAll(COLOR_WHITE, string);
				}
				else if(Aduty[playerid] == 1)
				{
				    format(string, sizeof(string), "[A] %s %s is no longer on duty as an administrator!",admtext,name);
				    Aduty[playerid] = 0;
                	SendClientMessageToAll(COLOR_WHITE, string);
				}
			}
		}
		else SendClientMessage(playerid, COLOR_LIGHTRED, "[Error]: You're not allowed to use that command!");
	}
	if (strcmp(cmd, "/name", true) ==0 )
    {
        if (PlayerInfo[playerid][pRank] >= 4)
        {
            tmp = strtok(cmdtext,idx);
            if(!strlen(tmp))
            {
                SendClientMessage(playerid, COLOR_WHITE2, "Function: {FFFFFF}/name off/on ");
                return 1;
            }
            if(strcmp(tmp,"off",true) == 0)
            {
                for(new i=0;i<GetMaxPlayers();i++) { ShowPlayerNameTagForPlayer(i, playerid, 0); }
                SendClientMessage(playerid,COLOR_RED,"Details: Your name tags are hidden");
                PlayerPlaySound(playerid, 1056, 0.0, 0.0, 0.0);
                nameoff[playerid] = 1;
                return 1;
		    }
            if(strcmp(tmp,"on",true) == 0)
            {
                for(new i=0;i<GetMaxPlayers();i++) { ShowPlayerNameTagForPlayer(i, playerid, 1); }
                SendClientMessage(playerid,COLOR_PINKY,"Details: Your name tags are viewable");
                PlayerPlaySound(playerid, 1057, 0.0, 0.0, 0.0);
                nameoff[playerid] = 0;
                return 1;
			}
        }
		else
		{
            SendClientMessage(playerid,COLOR_WHITE2,"Your are not a high enough rank");
		}
		return 1;
    }
