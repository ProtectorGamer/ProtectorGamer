public LoadClubs()
{
	new arrCoords[17][64];
	new strFromFile2[256];
	new File: file = fopen("LG/Estate/Businesses/club.ini", io_read);
	if (file)
	{
		new idx;
		while (idx < sizeof(ClubInfo))
		{
			fread(file, strFromFile2);
			split(strFromFile2, arrCoords, '|');
			ClubInfo[idx][clOwned] = strval(arrCoords[0]);
			ClubInfo[idx][clNum] = strval(arrCoords[1]);
			strmid(ClubInfo[idx][clOwner], arrCoords[2], 0, strlen(arrCoords[2]), 255);
			strmid(ClubInfo[idx][clMessage], arrCoords[3], 0, strlen(arrCoords[3]), 255);
			ClubInfo[idx][clEntrancex] = floatstr(arrCoords[4]);
			ClubInfo[idx][clEntrancey] = floatstr(arrCoords[5]);
			ClubInfo[idx][clEntrancez] = floatstr(arrCoords[6]);
			ClubInfo[idx][clExitx] = floatstr(arrCoords[7]);
			ClubInfo[idx][clExity] = floatstr(arrCoords[8]);
			ClubInfo[idx][clExitz] = floatstr(arrCoords[9]);
			ClubInfo[idx][clInt] = strval(arrCoords[10]);
			ClubInfo[idx][clPrice] = strval(arrCoords[11]);
			ClubInfo[idx][clEntranceCost] = strval(arrCoords[12]);
			ClubInfo[idx][clTill] = strval(arrCoords[13]);
			ClubInfo[idx][clProds] = strval(arrCoords[14]);
			ClubInfo[idx][clMaxProds] = strval(arrCoords[15]);
			ClubInfo[idx][clLock] = strval(arrCoords[16]);
			idx++;
		}
		fclose(file);
	}
	return 1;
}

public SaveClub()
{
    new idx;
	new File: file2;
	while (idx < sizeof(ClubInfo))
	{
		new coordsstring[256];
		format(coordsstring, sizeof(coordsstring), "%d|%d|%s|%s|%f|%f|%f|%f|%f|%f|%d|%d|%d|%d|%d|%d|%d\n",
		ClubInfo[idx][clOwned],
		ClubInfo[idx][clNum],
		ClubInfo[idx][clOwner],
		ClubInfo[idx][clMessage],
		ClubInfo[idx][clEntrancex],
		ClubInfo[idx][clEntrancey],
		ClubInfo[idx][clEntrancez],
		ClubInfo[idx][clExitx],
		ClubInfo[idx][clExity],
		ClubInfo[idx][clExitz],
		ClubInfo[idx][clInt],
		ClubInfo[idx][clPrice],
		ClubInfo[idx][clEntranceCost],
		ClubInfo[idx][clTill],
		ClubInfo[idx][clProds],
		ClubInfo[idx][clMaxProds],
		ClubInfo[idx][clLock]);
		if(idx == 0)
		{
			file2 = fopen("LG/Estate/Businesses/club.ini", io_write);
		}
		else
		{
			file2 = fopen("LG/Estate/Businesses/club.ini", io_append);
		}
		fwrite(file2, coordsstring);
		idx++;
		fclose(file2);
	}
	return 1;
}

