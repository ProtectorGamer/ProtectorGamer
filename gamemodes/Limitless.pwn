            SendClientMessage(playerid,COLOR_GREEN,"Function: {FFFFFF}/walk [0-13]");
            return 1;
		}
        new walk = strval(tmp);
	    if(walk < 0 || walk > 13)
	    {
		    SendClientMessage(playerid, COLOR_WHITE2, "From 0 To 13");
			return 1;
