							}
						}
					}
				}
			}
			if(strcmp(x_nr,"open",true) == 0)
	        {
	            for(new h = 0;h<MAX_BUY_V;h++)
	            {
                    new Float:vX,Float:vY,Float:vZ;
                    GetVehiclePos(h,vX,vY,vZ);
		            if(PlayerToPoint(3.0, playerid, vX,vY,vZ))
		            {
	                    if(GetCreatorID(h)!=0)
