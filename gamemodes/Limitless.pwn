	if(strcmp(cmd, "/fwithdraw", true) == 0)
	{
	    for(new h = 0; h < sizeof(HQInfo); h++)
	    {
			if(HQInfo[h][hqID] == PlayerInfo[playerid][pLeader])
			{
			    if (!PlayerToPoint(5.0, playerid,2308.7505,-13.2901,26.7422))
	            {
	                SendClientMessage(playerid, COLOR_GREY, "You are not at the Bank !");
	                return 1;
	            }
			    tmp = strtok(cmdtext, idx);
			    if(!strlen(tmp))
			    {
				    SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/fwithdraw [amount]");
				    format(string, sizeof(string), "You Have $%d in your faction account.", HQInfo[h][hqBank]);
				    SendClientMessage(playerid, COLOR_GRAD3, string);
				    return 1;
			    }
			    new cashdeposit = strval(tmp);
			    if(!strlen(tmp))
			    {
				    SendClientMessage(playerid, COLOR_GRAD2, "Function: {FFFFFF}/fwithdraw [amount]");
				    format(string, sizeof(string), "You Have $%d in your faction account.", HQInfo[h][hqBank]);
				    SendClientMessage(playerid, COLOR_GRAD3, string);
				    return 1;
			    }
			    if (cashdeposit > HQInfo[h][hqBank] || cashdeposit < 1)
			    {
				    SendClientMessage(playerid, COLOR_GRAD2, "You dont have that much !");
				    return 1;
			    }
			    Otman_GivePlayerMoney(playerid,cashdeposit);
			    HQInfo[h][hqBank]=HQInfo[h][hqBank]-cashdeposit;
			    format(string, sizeof(string), "You Have Withdrawn $%d from your faction account Total: $%d", cashdeposit,HQInfo[h][hqBank]);
			    SendClientMessage(playerid, COLOR_YELLOW, string);
			    SaveHQ();
			    return 1;
			}
		}
		return 1;
	}
	if(strcmp(cmd, "/fdeposit", true) == 0)
	{
	    for(new h = 0; h < sizeof(HQInfo); h++)
