public OnGameModeExit()
{
    SaveData();
    SaveDealer();
    SaveBiz();
    SaveShop();
    SaveHQ();
    SaveHouse();
    SaveRentCar();
    SaveClub();
    SaveAd();
    SavePhone();
    SaveGZ();
    djson_GameModeExit();
    Seifader_OnExit();
	return 1;
}

